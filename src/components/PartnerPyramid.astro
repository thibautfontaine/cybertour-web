---
/**
 * PartnerPyramid — pyramid layout of partners and sponsors,
 * narrowest at top (organisateur/platinium) widening to bronze tier at bottom.
 */

interface Sponsor {
  name: string;
  initials: string;
  tagline?: string;
}

interface SponsorTier {
  name: string;
  sponsors: Sponsor[];
  accent: string;
  accentBorder: string;
  accentBg: string;
  textSize: string;
  padding: string;
}

const tiers: SponsorTier[] = [
  {
    name: 'Platinium — Partenaire Principal',
    sponsors: [
      { name: 'OceanCloud Reunion', initials: 'OC', tagline: 'Hebergement souverain' },
    ],
    accent: 'text-purple-300',
    accentBorder: 'border-purple-400/40',
    accentBg: 'bg-purple-400/[0.06]',
    textSize: 'text-lg',
    padding: 'px-10 py-5',
  },
  {
    name: 'Gold',
    sponsors: [
      { name: 'CyberTropik', initials: 'CT', tagline: 'SOC & Threat Intelligence' },
      { name: 'SecurDom', initials: 'SD', tagline: 'Audit & Conformite DROM' },
    ],
    accent: 'text-gold',
    accentBorder: 'border-gold/40',
    accentBg: 'bg-gold/[0.06]',
    textSize: 'text-lg',
    padding: 'px-10 py-5',
  },
  {
    name: 'Silver',
    sponsors: [
      { name: 'ReunionNet Pro', initials: 'RN' },
      { name: 'VolcanData', initials: 'VD' },
      { name: 'IndianOcean IT', initials: 'IO' },
    ],
    accent: 'text-gray-300',
    accentBorder: 'border-gray-400/40',
    accentBg: 'bg-gray-400/[0.06]',
    textSize: 'text-base',
    padding: 'px-7 py-3.5',
  },
  {
    name: 'Bronze',
    sponsors: [
      { name: 'TropiCode', initials: 'TC' },
      { name: 'Lagon Digital', initials: 'LD' },
      { name: 'SudDev 974', initials: 'S9' },
      { name: 'Kreol Hosting', initials: 'KH' },
      { name: 'RunWifi', initials: 'RW' },
    ],
    accent: 'text-amber-600',
    accentBorder: 'border-amber-600/40',
    accentBg: 'bg-amber-600/[0.06]',
    textSize: 'text-sm',
    padding: 'px-5 py-2.5',
  },
];
---

<section class="relative py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col items-center gap-12">

      <!-- Level 1 — Organisateur -->
      <div class="reveal flex flex-col items-center gap-6 max-w-md w-full">
        <span class="font-mono text-sm tracking-widest uppercase text-gold">
          Organisateur
        </span>
        <div class="flex justify-center">
          <div class="partner-bubble px-8 py-4">
            <img
              src="/assets/logo-clusir.png"
              alt="CLUSIR Reunion Ocean Indien"
              class="h-20 sm:h-24 w-auto object-contain"
              loading="lazy"
            />
          </div>
        </div>
        <!-- Connecting line -->
        <div class="w-px h-8 bg-white/10"></div>
      </div>

      <!-- Level 2 — Partenaires -->
      <div class="reveal delay-1 flex flex-col items-center gap-6 max-w-2xl w-full">
        <span class="font-mono text-sm tracking-widest uppercase text-white/50">
          Partenaires
        </span>
        <div class="flex flex-wrap items-center justify-center gap-6">
          <div class="partner-bubble px-6 py-3">
            <img
              src="/assets/logo-univ-reunion.png"
              alt="Universite de La Reunion"
              class="h-14 sm:h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>
          <div class="partner-bubble px-6 py-3">
            <img
              src="/assets/logo-iut.png"
              alt="IUT de La Reunion"
              class="h-14 sm:h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>
          <div class="partner-bubble px-6 py-3">
            <img
              src="/assets/logo-esiroi.jpg"
              alt="ESIROI - Ecole d'Ingenieurs"
              class="h-14 sm:h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>
          <div class="partner-bubble px-6 py-3">
            <img
              src="/assets/logo-cyber-reunion.jpg"
              alt="Cyber Reunion"
              class="h-14 sm:h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>
        </div>
        <!-- Connecting line -->
        <div class="w-px h-8 bg-white/10"></div>
      </div>

      <!-- Sponsor Tiers -->
      {tiers.map((tier, i) => (
        <div class={`reveal delay-${i + 2} flex flex-col items-center gap-6 w-full ${i === 0 ? 'max-w-2xl' : i === 1 ? 'max-w-3xl' : i === 2 ? 'max-w-4xl' : 'max-w-5xl'}`}>
          <span class={`font-mono text-sm tracking-widest uppercase ${tier.accent}`}>
            Sponsor {tier.name}
          </span>

          <!-- Sponsor logos -->
          <div class="flex flex-wrap items-center justify-center gap-4">
            {tier.sponsors.map(s => (
              <div class={`partner-bubble ${tier.padding} flex items-center gap-3 ${tier.accentBorder} border`}>
                <div class={`shrink-0 w-12 h-12 rounded-lg ${tier.accentBg} ${tier.accentBorder} border flex items-center justify-center`}>
                  <span class={`font-mono font-bold ${tier.textSize} ${tier.accent}`}>{s.initials}</span>
                </div>
                <div class="flex flex-col">
                  <span class={`font-display font-bold ${tier.textSize} text-white/90`}>{s.name}</span>
                  {s.tagline && (
                    <span class="text-xs text-white/40 font-mono">{s.tagline}</span>
                  )}
                </div>
              </div>
            ))}
          </div>

          <!-- Connecting line (except last) -->
          {i < tiers.length - 1 && (
            <div class="w-px h-8 bg-white/10"></div>
          )}
        </div>
      ))}

    </div>
  </div>
</section>
