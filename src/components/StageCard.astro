---
import type { Stage } from "../data/stages";

interface Props {
  stage: Stage;
}

const { stage } = Astro.props;

const trackClassMap: Record<string, string> = {
  gold: "bento-track--gold",
  cyan: "bento-track--cyan",
  emerald: "bento-track--emerald",
  red: "bento-track--red",
};

const trackClass = trackClassMap[stage.accent] ?? "bento-track--gold";
---

<a
  href={stage.href}
  class:list={[
    "group topic-card bento-track",
    trackClass,
    "block bg-white/[0.03] border border-white/[0.06] rounded-2xl p-6 sm:p-8 hover:bg-white/[0.06] transition-all duration-300",
  ]}
>
  <!-- Header: track number + title -->
  <div class="flex items-baseline gap-3 mb-2">
    <span
      class="shrink-0 font-mono text-xs tracking-widest uppercase"
      style={`color: ${stage.accentHex}`}
    >{stage.trackNumber}</span>
    <h3 class="font-display font-bold text-lg sm:text-xl text-white">
      {stage.direction}
    </h3>
  </div>

  <!-- Theme -->
  <p class="text-white/50 text-sm mb-5">{stage.theme}</p>

  <!-- Info grid: date, lieu, capacity -->
  <div class="grid grid-cols-[1fr_auto] gap-x-4 gap-y-2 mb-5 text-sm">
    <!-- Date -->
    <div class="flex items-center gap-2 text-white/70">
      <svg class="w-4 h-4 shrink-0" style={`color: ${stage.accentHex}`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <path d="M16 2v4M8 2v4M3 10h18"/>
      </svg>
      <span>{stage.dateShort}</span>
    </div>
    <!-- Capacity -->
    <span
      class="inline-flex items-center justify-center px-2.5 py-0.5 rounded-full text-xs font-mono font-bold"
      style={`background: ${stage.accentHex}18; color: ${stage.accentHex}`}
    >
      {stage.capacity}p
    </span>
    <!-- Lieu -->
    <div class="flex items-center gap-2 text-white/70 col-span-2">
      <svg class="w-4 h-4 shrink-0" style={`color: ${stage.accentHex}`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      <span>{stage.lieu}</span>
    </div>
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mb-5">
    {stage.highlights.map((tag) => (
      <span
        class="px-2 py-0.5 rounded text-[11px] font-mono"
        style={`background: ${stage.accentHex}10; color: ${stage.accentHex}B3`}
      >
        {tag}
      </span>
    ))}
  </div>

  <!-- CTA -->
  <span
    class="inline-flex items-center gap-2 text-sm font-bold tracking-wide uppercase group-hover:gap-3 transition-all duration-300"
    style={`color: ${stage.accentHex}`}
  >
    Decouvrir
    <span aria-hidden="true">&rarr;</span>
  </span>
</a>
