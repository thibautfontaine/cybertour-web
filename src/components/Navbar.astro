---
interface Props {
  currentPage?: string;
}

const { currentPage } = Astro.props;

const navLinks = [
  { label: "À propos", href: "/#about" },
  { label: "Les Étapes", href: "/#etapes" },
  { label: "CTF", href: "/#ctf" },
  { label: "Speakers", href: "/#speakers" },
  { label: "Sponsors", href: "/#sponsors" },
  { label: "Inscriptions", href: "/#inscriptions", soon: true },
];

const ctaLink = { label: "Contact", href: "/#contact" };
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-transparent transition-all duration-300" data-scrolled="false">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <img src="/assets/logo-clusir-roi-sombre.png" alt="CLUSIR Réunion Océan Indien" class="h-14 sm:h-16 w-auto transition-transform group-hover:scale-105" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        link.soon ? (
          <span class="text-sm font-medium tracking-wider uppercase text-white/25 line-through cursor-default select-none" title="Inscriptions bientôt disponibles">
            {link.label}
          </span>
        ) : (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium hover:text-gold transition-colors tracking-wider uppercase",
              currentPage && link.href.startsWith(`/${currentPage}`)
                ? "text-gold"
                : "text-white/70",
            ]}
          >
            {link.label}
          </a>
        )
      ))}
      <a href={ctaLink.href} class="btn-outline text-xs py-2 px-5">{ctaLink.label}</a>
    </div>

    <!-- Mobile burger -->
    <button id="menu-toggle" class="md:hidden text-white" aria-label="Menu" aria-expanded="false">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-navy-dark/95 backdrop-blur-lg border-t border-white/10">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map((link) => (
        link.soon ? (
          <span class="text-sm font-medium uppercase text-white/25 line-through cursor-default">
            {link.label}
          </span>
        ) : (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium hover:text-gold transition-colors uppercase",
              currentPage && link.href.startsWith(`/${currentPage}`)
                ? "text-gold"
                : "text-white/70",
            ]}
          >
            {link.label}
          </a>
        )
      ))}
      <a href={ctaLink.href} class="text-sm font-medium text-white/70 hover:text-gold transition-colors uppercase">{ctaLink.label}</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = mobileMenu?.querySelectorAll('a');

  // Scroll — add background when user scrolls past 60px
  function onScroll() {
    if (!nav) return;
    const scrolled = window.scrollY > 60;
    nav.style.backgroundColor = scrolled ? 'var(--nav-scrolled)' : 'transparent';
    nav.style.backdropFilter = scrolled ? 'blur(12px)' : 'none';
    nav.style.borderBottom = scrolled ? '1px solid rgba(255,255,255,0.06)' : 'none';
    nav.dataset.scrolled = String(scrolled);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // run on page load in case of direct anchor navigation

  // Mobile menu — toggle open/close
  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden') === false;
    mobileMenu?.classList.toggle('hidden', isOpen);
    menuToggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Mobile menu — close when a link is clicked
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuToggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
