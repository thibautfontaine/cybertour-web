---
import { stages } from "../data/stages";

/**
 * Geographic positions (%) for each stage on the island silhouette.
 * Keys match the stage `id` field.
 */
const positions: Record<string, { top: number; left: number }> = {
  nord:  { top: 15, left: 45 },   // Saint-Denis — cote nord
  ouest: { top: 28, left: 18 },   // Le Port — cote nord-ouest
  est:   { top: 25, left: 72 },   // Saint-Andre — cote nord-est
  sud:   { top: 75, left: 32 },   // Saint-Pierre — cote sud-ouest
};

/** Shield path is drawn directly in SVG using bezier curves through the 4 stage positions */
---

<section id="carte" class="reveal relative py-20 md:py-28 overflow-hidden">
  <!-- Section heading -->
  <div class="text-center mb-12 md:mb-16 px-4">
    <p class="font-mono text-xs tracking-widest uppercase text-gold-dim mb-3">
      // ITINERAIRE
    </p>
    <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white">
      4 etapes a travers l'ile
    </h2>
  </div>

  <!-- Map container -->
  <div class="relative mx-auto max-w-4xl aspect-square md:aspect-[4/3] px-4">
    <!-- Island silhouette background -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <img
        src="/assets/reunion-silhouette.png"
        alt=""
        aria-hidden="true"
        class="w-full h-full object-contain opacity-30"
        style="filter: drop-shadow(0 0 60px rgba(255, 222, 89, 0.25)) drop-shadow(0 0 120px rgba(255, 222, 89, 0.15));"
      />
    </div>


    <!-- Stage points -->
    {stages.map((stage, i) => {
      const pos = positions[stage.id];
      if (!pos) return null;

      return (
        <a
          href={stage.href}
          class="map-point group absolute z-10 flex flex-col items-center -translate-x-1/2 -translate-y-1/2 transition-transform duration-300 hover:scale-110"
          style={`top: ${pos.top}%; left: ${pos.left}%;`}
          data-stage={stage.id}
        >
          {/* Pulsing dot */}
          <span class="relative flex h-4 w-4 md:h-5 md:w-5">
            <span
              class="absolute inset-0 rounded-full animate-ping opacity-50"
              style={`background-color: ${stage.accentHex};`}
            />
            <span
              class="relative inline-flex h-full w-full rounded-full border-2 border-navy-dark"
              style={`background-color: ${stage.accentHex}; box-shadow: 0 0 12px ${stage.accentHex}80;`}
            />
          </span>

          {/* Label */}
          <span
            class="mt-2 md:mt-3 whitespace-nowrap rounded-lg bg-navy-dark backdrop-blur-md px-3 py-2 md:px-4 md:py-2.5 border-2 shadow-lg transition-all duration-300 group-hover:border-opacity-80"
            style={`border-color: ${stage.accentHex}60; box-shadow: 0 4px 20px rgba(0,0,0,0.4);`}
          >
            <span class="font-mono text-xs md:text-sm font-bold tracking-wider uppercase" style={`color: ${stage.accentHex};`}>
              {stage.dateShort}
            </span>
            <span class="block font-body text-xs md:text-sm text-white font-medium leading-tight mt-0.5">
              {stage.lieu}
            </span>
          </span>

          {/* Hover glow */}
          <span
            class="absolute -inset-3 rounded-full opacity-0 group-hover:opacity-20 transition-opacity duration-300 blur-xl pointer-events-none"
            style={`background-color: ${stage.accentHex};`}
          />
        </a>
      );
    })}
  </div>

  <!-- Timeline bar -->
  <div class="relative mt-14 md:mt-20 mx-auto max-w-4xl px-6">
    {/* Connecting line */}
    <div class="absolute top-5 left-[8%] right-[8%] h-0.5 bg-white/15 rounded-full" aria-hidden="true" />

    <div class="flex justify-between items-start">
      {stages.map((stage) => (
        <a href={stage.href} class="group relative flex flex-col items-center text-center flex-1 py-2">
          {/* Dot */}
          <span
            class="relative z-10 h-3 w-3 md:h-4 md:w-4 rounded-full border-2 border-navy-dark transition-transform duration-300 group-hover:scale-150"
            style={`background-color: ${stage.accentHex}; box-shadow: 0 0 12px ${stage.accentHex}80;`}
          />

          {/* Date */}
          <span class="mt-3 font-mono text-xs md:text-sm font-bold tracking-wider uppercase" style={`color: ${stage.accentHex};`}>
            {stage.dateShort}
          </span>

          {/* Direction */}
          <span class="font-display text-xs md:text-sm text-white font-semibold uppercase tracking-wide mt-0.5">
            {stage.direction}
          </span>

          {/* Lieu */}
          <span class="font-body text-[10px] md:text-xs text-white/60 mt-0.5">
            {stage.lieu}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .map-point:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 4px;
    border-radius: 4px;
  }
</style>
