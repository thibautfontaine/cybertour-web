---
import StageLayout from '../layouts/StageLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Timeline, { type TimelineItem } from '../components/Timeline.astro';
import { stages } from '../data/stages';
const stage = stages.find(s => s.id === 'est')!;

const programme: TimelineItem[] = [
  { time: '08:30 - 09:00', title: 'Accueil des participants' },
  { time: '09:00 - 09:15', title: 'Introduction et mot de bienvenue', speaker: 'CLUSIR ROI' },
  { isSection: true, title: 'Panorama des formations cyber' },
  { time: '09:15 - 09:45', title: 'Les formations cyber a l\'Universite de La Reunion', org: 'UNIVERSITE' },
  { time: '09:45 - 10:15', title: 'Le cursus cybersecurite d\'Epitech', org: 'EPITECH' },
  { time: '10:15 - 10:45', title: 'Pause cafe', isPause: true },
  { time: '10:45 - 11:15', title: 'Formations en alternance et professionnalisation', org: 'IUT / ESIROI' },
  { time: '11:15 - 11:45', title: 'Certifications et parcours de reconversion', org: 'A CONFIRMER' },
  { isSection: true, title: 'Speed dating stages & alternances' },
  { time: '12:00 - 13:30', title: 'Dejeuner et networking', isPause: true },
  { time: '13:30 - 16:00', title: 'Speed dating : rencontres etudiants / entreprises (sessions de 8 min)' },
  { time: '16:00 - 16:30', title: 'Cloture et bilan de la journee' },
];
---

<StageLayout stage={stage}>
  <Navbar slot="navbar" currentPage="est" />

  <!-- Programme section -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="reveal">
        <span class="font-mono text-emerald-400/60 text-sm tracking-widest uppercase">Programme</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl mt-4">Formations Cyber a La Reunion</h2>
        <p class="text-white/50 mt-4 text-lg max-w-3xl">
          Focus sur l'ecosysteme de formation en cybersecurite a La Reunion. Les ecoles presentent leurs cursus et parcours
          de formation, suivis de rencontres directes entre etudiants et entreprises.
        </p>
      </div>

      <!-- Timeline -->
      <div class="reveal delay-1 mt-14">
        <Timeline accentHex={stage.accentHex} items={programme} />
      </div>

      <!-- School cards -->
      <div class="reveal delay-2 mt-12">
        <h3 class="font-display font-semibold text-xl mb-8">Ecoles et formations presentes</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          {['Epitech Reunion', 'ESIROI', 'IUT de La Reunion', 'Universite de La Reunion', 'CNAM Reunion', 'Lycee Lislet Geoffroy', 'ESIEA', 'Sup de Vinci'].map(name => (
            <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 text-center hover:border-emerald-400/20 transition-colors">
              <span class="font-display font-semibold text-sm text-white/70">{name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Speed Dating CTA -->
      <div class="reveal delay-3 mt-12 text-center">
        <div class="bg-emerald-400/[0.06] border border-emerald-400/[0.15] rounded-2xl p-8">
          <h3 class="font-display font-bold text-2xl mb-3">Speed Dating Stages & Alternances</h3>
          <p class="text-white/50 text-sm font-body max-w-xl mx-auto mb-6">
            Rencontrez directement les entreprises qui recrutent en cybersecurite a La Reunion.
            Apportez votre CV et venez echanger en face-a-face avec les recruteurs.
          </p>
          <a href="/jobs" class="btn-primary inline-block rounded-lg font-display mt-2">
            Speed Dating Stages & Alternances &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</StageLayout>
