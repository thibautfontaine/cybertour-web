---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Mentions Legales | Cyber Tour Réunion 2026" description="Mentions légales du site Cyber Tour Réunion 2026.">
  <Navbar />

  <main class="bg-navy-dark min-h-screen pt-32 pb-20">
    <div class="max-w-3xl mx-auto px-6">

      <h1 class="font-display text-3xl md:text-4xl font-bold text-white mb-12 reveal">
        Mentions légales
      </h1>

      <!-- Editeur du site -->
      <section class="border-b border-white/[0.06] pb-8 mb-8 reveal">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Editeur du site</h2>
        <div class="text-white/70 leading-relaxed space-y-1">
          <p><strong class="text-white">CLUSIR ROI</strong> — Club de la Sécurité de l'Information en Reseau — Reunion et Océan Indien</p>
          <p>Association loi 1901</p>
          <p>SIREN : 539 437 426 | SIRET : 539 437 426 00023</p>
          <p>RNA : W9R1003737</p>
          <p>Siege social : Immeuble Altea, 41 rue de la Pepiniere, 97438 Sainte-Marie, La Réunion</p>
          <p>Comite d'organisation : <a href="mailto:team@cybertour.re" class="text-gold hover:underline">team@cybertour.re</a></p>
        </div>
      </section>

      <!-- Directeur de la publication -->
      <section class="border-b border-white/[0.06] pb-8 mb-8 reveal">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Directeur de la publication</h2>
        <p class="text-white/70 leading-relaxed">
          Le directeur de la publication est le President du CLUSIR Réunion Océan Indien.
        </p>
      </section>

      <!-- Hebergement -->
      <section class="border-b border-white/[0.06] pb-8 mb-8 reveal">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Hebergement</h2>
        <div class="text-white/70 leading-relaxed space-y-1">
          <p><strong class="text-white">GitHub Pages</strong> — GitHub, Inc.</p>
          <p>88 Colin P. Kelly Jr St, San Francisco, CA 94107, United States</p>
          <p>Code source : <a href="https://github.com/thibautfontaine/cybertour-web" target="_blank" rel="noopener" class="text-gold hover:underline">github.com/thibautfontaine/cybertour-web</a></p>
        </div>
      </section>

      <!-- Conception et developpement -->
      <section class="border-b border-white/[0.06] pb-8 mb-8 reveal">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Conception et developpement</h2>
        <p class="text-white/70 leading-relaxed">
          <a href="https://www.linkedin.com/in/thibaut-fontaine" target="_blank" rel="noopener" class="text-gold hover:underline">Thibaut Fontaine</a> — Membre du bureau du CLUSIR Réunion Océan Indien.
        </p>
      </section>

      <!-- Propriete intellectuelle -->
      <section class="border-b border-white/[0.06] pb-8 mb-8 reveal">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Propriete intellectuelle</h2>
        <p class="text-white/70 leading-relaxed">
          L'ensemble des contenus de ce site (textes, images, logos, elements graphiques, videos)
          est protege par le Code de la propriete intellectuelle. Toute reproduction ou représentation,
          totale ou partielle, est interdite sans autorisation ecrite du CLUSIR Réunion Océan Indien.
        </p>
      </section>

      <!-- Donnees personnelles et cookies -->
      <section class="border-b border-white/[0.06] pb-8 mb-8 reveal">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Donnees personnelles et cookies</h2>
        <p class="text-white/70 leading-relaxed mb-4">
          Conformement au Reglement General sur la Protection des Donnees (RGPD) et a la loi Informatique et Libertes :
        </p>
        <ul class="text-white/70 leading-relaxed space-y-2 list-disc list-inside">
          <li>Ce site <strong class="text-white">ne collecte aucune donnee personnelle</strong>.</li>
          <li>Ce site <strong class="text-white">n'utilise aucun cookie</strong> ni traceur.</li>
          <li>Aucun outil de suivi, d'analyse ou de profilage n'est deploye.</li>
          <li>Aucune donnee n'est transmise a des tiers.</li>
        </ul>
      </section>

      <!-- Liens externes -->
      <section class="border-b border-white/[0.06] pb-8 mb-8 reveal">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Liens externes</h2>
        <p class="text-white/70 leading-relaxed">
          Ce site peut contenir des liens vers des sites tiers. Le CLUSIR Réunion Océan Indien
          ne saurait etre tenu responsable du contenu de ces sites externes ni de leur politique
          de protection des donnees personnelles.
        </p>
      </section>

      <!-- Contact -->
      <section class="reveal">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Contact</h2>
        <p class="text-white/70 leading-relaxed">
          Pour toute question relative au site ou a l'événement :
          <a href="mailto:team@cybertour.re" class="text-gold hover:underline">team@cybertour.re</a>
        </p>
      </section>

    </div>
  </main>

  <Footer />
</Layout>
