---
import StageLayout from '../layouts/StageLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { stages } from '../data/stages';
const stage = stages.find(s => s.id === 'ouest')!;
---

<StageLayout stage={stage}>
  <Navbar slot="navbar" currentPage="ouest" />

  <!-- Programme section -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="reveal">
        <span class="font-mono text-cyan-400/60 text-sm tracking-widest uppercase">Programme</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl mt-4">Rencontre Offreurs & Entreprises</h2>
        <p class="text-white/50 mt-4 text-lg max-w-3xl">
          Une journee au format B2B dediee aux rencontres entre offreurs de solutions cyber et entreprises reunionnaises.
          Presentations de solutions, tables rondes thematiques et networking pour repondre aux enjeux de securite du tissu economique local.
        </p>
      </div>

      <!-- Programme cards -->
      <div class="reveal delay-2 mt-12">
        <div class="grid sm:grid-cols-3 gap-6">
          {[
            { title: 'Presentations solutions', desc: 'Decouvrez les solutions cyber adaptees aux entreprises reunionnaises.' },
            { title: 'Tables rondes thematiques', desc: 'Echanges entre decideurs IT, RSSI et offreurs sur les enjeux locaux.' },
            { title: 'Networking B2B', desc: 'Rencontres qualifiees entre professionnels de la cybersecurite.' },
          ].map(item => (
            <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-6 hover:border-cyan-400/20 transition-colors">
              <h3 class="font-display font-semibold text-lg mb-2">{item.title}</h3>
              <p class="text-white/50 text-sm font-body">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Afternoon note -->
      <div class="reveal delay-3 mt-10">
        <div class="bg-cyan-400/[0.06] border border-cyan-400/[0.15] rounded-xl p-6 flex items-start gap-4">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-cyan-400/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
          </div>
          <div>
            <h4 class="font-display font-semibold text-sm mb-1 text-cyan-400">Apres-midi</h4>
            <p class="text-white/50 text-sm font-body">
              Gestion de crise l'apres-midi : simulation d'incident cyber en conditions reelles, animee par des experts.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</StageLayout>
