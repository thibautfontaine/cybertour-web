---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import MapReunion from '../components/MapReunion.astro';
import StageCard from '../components/StageCard.astro';
import PartnerPyramid from '../components/PartnerPyramid.astro';
import { stages } from '../data/stages';
---

<Layout title="Cyber Tour Réunion 2026 | 19-23 Octobre - 4 Étapes">

  <!-- ===== NAVBAR ===== -->
  <Navbar />

  <!-- ===== HERO ===== -->
  <section id="main-content" class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background image with overlay -->
    <div class="absolute inset-0">
      <img src="/assets/hero-bg.jpg" alt="" width="1920" height="1080" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/80 via-navy-dark/70 to-navy-dark"></div>
    </div>

    <!-- Grid overlay -->
    <div class="absolute inset-0 cyber-grid"></div>

    <!-- Scan line effect -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute left-0 right-0 h-px bg-gold/20 animate-scan"></div>
    </div>

    <!-- Glow orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-navy rounded-full animate-pulse-glow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-gold/20 rounded-full animate-pulse-glow" style="animation-delay: 2s;"></div>

    <!-- Floating island silhouette -->
    <div class="absolute right-0 bottom-0 w-[500px] h-[500px] opacity-[0.06] animate-float pointer-events-none">
      <img src="/assets/reunion-silhouette.png" alt="" class="w-full h-full object-contain" />
    </div>

    <!-- Hero content -->
    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
      <!-- Event badge -->
      <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-5 py-2 mb-8" style="animation: slide-up 0.8s ease-out both;">
        <span class="w-2 h-2 bg-gold rounded-full animate-pulse"></span>
        <span class="text-sm font-mono text-white/60 tracking-widest uppercase">Cybermois 2026 &mdash; La Réunion</span>
      </div>

      <!-- Main title -->
      <h1 class="font-display font-extrabold leading-relaxed mb-6" style="animation: slide-up 0.8s ease-out 0.15s both;">
        <span class="glitch-wrapper block">
          <span class="glitch text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight text-white" data-text="CYBER">CYBER</span>
        </span>
        <span class="block text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight">
          <span class="text-gold">TOUR</span>
          <span class="text-white/20 ml-2 md:ml-4">&#47;&#47;</span>
        </span>
        <span class="block text-3xl sm:text-4xl md:text-5xl tracking-[0.2em] mt-4 reunion-outline">REUNION</span>
      </h1>

      <!-- Date & location -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 mb-10" style="animation: slide-up 0.8s ease-out 0.3s both;">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          <span class="font-display font-semibold text-lg tracking-wide">19 &mdash; 23 OCTOBRE 2026</span>
        </div>
        <span class="hidden sm:block w-1 h-1 bg-gold rounded-full"></span>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="font-display font-semibold text-lg tracking-wide">4 ÉTAPES &middot; TOUTE L'ILE</span>
        </div>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4" style="animation: slide-up 0.8s ease-out 0.45s both;">
        <a href="#etapes" class="btn-primary rounded-lg font-display">Découvrir le parcours</a>
        <a href="#contact" class="btn-outline rounded-lg font-display text-sm">Contact</a>
      </div>

      <!-- Context pills — qualification rapide pour le visiteur -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-6" style="animation: slide-up 0.8s ease-out 0.55s both;">
        <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-mono tracking-wider border border-emerald-400/25 bg-emerald-400/[0.07] text-emerald-400">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
          Entrée gratuite
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-mono tracking-wider border border-gold/25 bg-gold/[0.07] text-gold">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Places limitées
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-mono tracking-wider border border-white/15 bg-white/[0.05] text-white/60">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          Présentiel + streaming
        </span>
      </div>

      <!-- Countdown -->
      <div class="mt-16 flex items-center justify-center gap-6 sm:gap-10" style="animation: slide-up 0.8s ease-out 0.6s both;">
        <div class="text-center">
          <span id="cd-days" class="block font-mono text-3xl sm:text-4xl font-bold text-gold tabular-nums">---</span>
          <span class="text-xs text-white/55 uppercase tracking-widest">Jours</span>
        </div>
        <span class="text-white/20 text-2xl font-light">:</span>
        <div class="text-center">
          <span id="cd-hours" class="block font-mono text-3xl sm:text-4xl font-bold text-white tabular-nums">--</span>
          <span class="text-xs text-white/55 uppercase tracking-widest">Heures</span>
        </div>
        <span class="text-white/20 text-2xl font-light">:</span>
        <div class="text-center">
          <span id="cd-mins" class="block font-mono text-3xl sm:text-4xl font-bold text-white tabular-nums">--</span>
          <span class="text-xs text-white/55 uppercase tracking-widest">Min</span>
        </div>
        <span class="text-white/20 text-2xl font-light">:</span>
        <div class="text-center">
          <span id="cd-secs" class="block font-mono text-3xl sm:text-4xl font-bold text-white/50 tabular-nums">--</span>
          <span class="text-xs text-white/55 uppercase tracking-widest">Sec</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/45">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent"></div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="about" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <!-- Section header -->
      <div class="reveal mb-20">
        <span class="section-label">01 // À propos</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          L'événement cyber<br/><span class="text-gold">de référence</span> a La Réunion
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Text block -->
        <div class="space-y-8">
          <p class="reveal delay-1 text-lg text-white/70 leading-relaxed">
            <strong class="text-white font-semibold">Une semaine. Quatre étapes. Toute l'île.</strong>
            Le <strong class="text-white font-semibold">Cyber Tour Réunion</strong> est le rendez-vous annuel
            de la cybersécurité a La Réunion. Organisé dans le cadre du
            <strong class="text-gold font-semibold">Cybermois</strong> par le
            <strong class="text-white font-semibold">CLUSIR Réunion Océan Indien</strong>,
            il reunit decideurs, professionnels et etudiants autour d'un objectif commun :
            renforcer la résilience numérique du territoire.
          </p>
          <p class="reveal delay-2 text-lg text-white/70 leading-relaxed">
            En 2025 : <strong class="text-white font-semibold">220 participants</strong>,
            <strong class="text-white font-semibold">600 vues</strong> en replay,
            <strong class="text-white font-semibold">2 articles</strong> dans Le Quotidien.
            En 2026, le format évolue avec 4 étapes du Nord au Sud pour toucher tous les publics de l'île.
          </p>

          <!-- Stats -->
          <div class="reveal delay-3 grid grid-cols-3 gap-6 pt-6">
            <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
              <span class="block font-display font-extrabold text-3xl text-gold">4</span>
              <span class="text-sm text-white/50 mt-1">Étapes</span>
            </div>
            <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
              <span class="block font-display font-extrabold text-3xl text-gold">5</span>
              <span class="text-sm text-white/50 mt-1">Jours</span>
            </div>
            <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
              <span class="block font-display font-extrabold text-3xl text-gold">600+</span>
              <span class="text-sm text-white/50 mt-1">Vues YouTube</span>
            </div>
          </div>
        </div>

        <!-- Visual block -->
        <div class="reveal-right delay-2 relative">
          <div class="relative rounded-2xl overflow-hidden border border-white/10">
            <img src="/assets/cybertour-asset-web-site.png" alt="Cyber Tour Réunion" class="w-full h-auto" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-dark/60 to-transparent"></div>
          </div>
          <!-- Decorative shield -->
          <div class="absolute -top-8 -right-8 w-24 h-24 text-gold/20 animate-float" style="animation-delay: 1s;">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
            </svg>
          </div>
          <!-- Glow -->
          <div class="absolute -bottom-12 -left-12 w-48 h-48 bg-navy rounded-full blur-[80px] opacity-60"></div>
        </div>
      </div>

      <!-- P3 — Micro-CTA vers le parcours -->
      <div class="reveal delay-4 flex items-center justify-center mt-16 pt-10 border-t border-white/[0.05]">
        <a
          href="#etapes"
          class="group inline-flex items-center gap-3 font-mono text-sm text-white/40 hover:text-gold transition-colors duration-200 tracking-wide"
        >
          <span>Voir les 4 étapes du tour</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CARTE DU TOUR / ÉTAPES ===== -->
  <section id="etapes" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-deep to-navy-dark"></div>
    <div class="absolute inset-0 cyber-grid opacity-50"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="reveal mb-20 text-center">
        <span class="font-mono text-gold/80 text-sm tracking-widest uppercase">02 // Le Parcours</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          4 étapes a travers <span class="text-gold">toute l'île</span>
        </h2>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-lg">
          Chaque jour, un lieu. Chaque lieu, un enjeu. De Saint-Denis a Saint-Pierre, la cybersécurité fait le tour de l'île.
        </p>
        <!-- C4 — Dates bien visibles -->
        <div class="inline-flex items-center gap-2 mt-6 px-4 py-2 rounded-full border border-gold/20 bg-gold/[0.06]">
          <svg class="w-4 h-4 text-gold/70 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          <span class="font-mono text-sm text-gold/80 font-bold tracking-wider">19 — 23 OCTOBRE 2026</span>
        </div>
      </div>
      <MapReunion />
      <!-- Stage cards bento grid -->
      <div class="grid md:grid-cols-2 gap-6 mt-16">
        {stages.map(stage => <StageCard stage={stage} />)}
      </div>
    </div>
  </section>

  <!-- ===== CTF CYBERMOIS ===== -->
  <section id="ctf" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6">
      <div class="reveal mb-16 text-center">
        <span class="font-mono text-gold/80 text-sm tracking-widest uppercase">03 // CTF</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          Championnat Reunionnais<br/>de <span class="text-gold">Cybersécurité</span>
        </h2>
        <p class="text-white/60 mt-4 max-w-2xl mx-auto text-xl font-display italic">
          Reunir les talents d'aujourd'hui pour batir le hub cyber de demain.
        </p>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-lg">
          Un CTF tout au long du mois d'octobre pour le <strong class="text-gold font-semibold">Cybermois 2026</strong>, en partenariat avec <a href="https://sec-dojo.com/fr" target="_blank" rel="noopener noreferrer" class="text-gold font-semibold hover:text-gold/80 transition-colors">Sec-Dojo</a> et <strong class="text-white font-semibold">Cyber Reunion</strong>.
        </p>
      </div>

      <div class="reveal delay-1 max-w-3xl mx-auto">
        <div class="relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 sm:p-10 overflow-hidden">
          <!-- Decorative corner -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-gold/5 to-transparent"></div>

          <div class="flex flex-col sm:flex-row items-start gap-6">
            <!-- Icon -->
            <div class="shrink-0 w-16 h-16 rounded-xl bg-gold/10 border border-gold/20 flex items-center justify-center">
              <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5"/>
              </svg>
            </div>

            <!-- Content -->
            <div class="space-y-4">
              <div class="flex flex-wrap items-center gap-3">
                <span class="inline-flex items-center gap-1.5 bg-gold/10 border border-gold/20 rounded-full px-3 py-1 text-xs font-mono text-gold tracking-wider uppercase">
                  <span class="w-1.5 h-1.5 bg-gold rounded-full animate-pulse"></span>
                  Octobre 2026
                </span>
                <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 rounded-full px-3 py-1 text-xs font-mono text-white/60 tracking-wider uppercase">
                  Tout le mois
                </span>
              </div>

              <p class="text-white/70 leading-relaxed">
                Testez vos compétences en cybersécurité a travers des challenges techniques sur la plateforme
                <a href="https://sec-dojo.com/fr" target="_blank" rel="noopener noreferrer" class="text-gold hover:text-gold/80 transition-colors font-semibold">SecDojo</a> :
                Linux, Windows, Network, Web et plus encore.
                Ouvert a tous les niveaux, du debutant au confirme.
              </p>

              <div class="pt-3">
                <span class="text-xs text-white/40 font-mono tracking-wider block mb-3">En partenariat avec</span>
                <div class="flex flex-wrap items-center gap-4">
                  <a href="https://sec-dojo.com/fr" target="_blank" rel="noopener noreferrer" class="partner-bubble px-5 py-2.5 hover:shadow-[0_4px_20px_rgba(0,0,0,0.2)]" aria-label="SecDojo">
                    <img src="/assets/logo-secdojo.png" alt="SecDojo" class="h-8 w-auto object-contain" loading="lazy" />
                  </a>
                  <a href="https://www.linkedin.com/company/cyber-reunion/" target="_blank" rel="noopener noreferrer" class="partner-bubble px-5 py-2.5 hover:shadow-[0_4px_20px_rgba(0,0,0,0.2)]" aria-label="Cyber Reunion">
                    <img src="/assets/logo-cyber-reunion.jpg" alt="Cyber Reunion" class="h-8 w-auto object-contain" loading="lazy" />
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Terminal-style teaser -->
          <div class="mt-8 bg-black/40 border border-white/[0.06] rounded-lg p-4 font-mono text-sm">
            <p class="text-emerald-400/80"><span class="text-gold/80">$</span> ./ctf --status</p>
            <p class="text-white/50 mt-1">Plateforme: <span class="text-gold">SecDojo</span> | Duree: <span class="text-white/70">Octobre 2026</span></p>
            <p class="text-white/50">Categories: <span class="text-white/70">Linux, Windows, Network, Web</span></p>
            <p class="text-gold mt-1 terminal-typing">Preparing challenges<span class="terminal-dots">...</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SPEAKERS ===== -->
  <section id="speakers" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="reveal mb-20 text-center">
        <span class="font-mono text-gold/80 text-sm tracking-widest uppercase">04 // Speakers</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          Nos <span class="text-gold">Conferenciers</span>
        </h2>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-lg">
          Des spécialistes reconnus en cybersécurité partagent leur expertise et leurs retours d'expérience.
        </p>
      </div>

      <!-- Encrypted overlay container -->
      <div class="relative">
        <!-- Speaker cards (blurred) -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 blur-[6px] select-none pointer-events-none" aria-hidden="true">
          <!-- Speaker 1 -->
          <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 text-center">
            <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-navy to-slate-mid border-2 border-white/10 flex items-center justify-center">
              <span class="font-display font-bold text-3xl text-gold/80">??</span>
            </div>
            <h3 class="font-display font-bold text-xl">██████ ██████</h3>
            <p class="font-mono text-xs text-gold/70 mt-2 tracking-wider uppercase">██████████</p>
            <p class="text-white/55 text-sm mt-4 leading-relaxed">
              ████████ ██ ████████ ██ ███████ ██ █████████ ██ █████████.
            </p>
          </div>

          <!-- Speaker 2 -->
          <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 text-center">
            <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-navy to-slate-mid border-2 border-white/10 flex items-center justify-center">
              <span class="font-display font-bold text-3xl text-gold/80">??</span>
            </div>
            <h3 class="font-display font-bold text-xl">██████ ██████</h3>
            <p class="font-mono text-xs text-gold/70 mt-2 tracking-wider uppercase">██████████</p>
            <p class="text-white/55 text-sm mt-4 leading-relaxed">
              ████████ ██ ████████ ██ ███████ ██ █████████ ██ █████████.
            </p>
          </div>

          <!-- Speaker 3 -->
          <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 text-center sm:col-span-2 lg:col-span-1">
            <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-navy to-slate-mid border-2 border-white/10 flex items-center justify-center">
              <span class="font-display font-bold text-3xl text-gold/80">??</span>
            </div>
            <h3 class="font-display font-bold text-xl">██████ ██████</h3>
            <p class="font-mono text-xs text-gold/70 mt-2 tracking-wider uppercase">██████████</p>
            <p class="text-white/55 text-sm mt-4 leading-relaxed">
              ████████ ██ ████████ ██ ███████ ██ █████████ ██ █████████.
            </p>
          </div>
        </div>

        <!-- Terminal overlay -->
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="terminal-window bg-black/80 backdrop-blur-md border border-gold/20 rounded-xl px-8 py-6 max-w-md w-full font-mono text-sm">
            <div class="flex items-center gap-2 mb-4 pb-3 border-b border-white/10">
              <span class="w-3 h-3 rounded-full bg-red/80"></span>
              <span class="w-3 h-3 rounded-full bg-gold/60"></span>
              <span class="w-3 h-3 rounded-full bg-emerald-400/60"></span>
              <span class="ml-3 text-white/45 text-xs">speakers.decrypt</span>
            </div>
            <div class="space-y-2">
              <p class="text-emerald-400/80"><span class="text-gold/80">$</span> cat /speakers/2026.conf</p>
              <p class="text-red/80">ERROR: Access denied. File encrypted.</p>
