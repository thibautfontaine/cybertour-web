---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cyber Tour Reunion 2026 | CLUSIR ROI | 22 Octobre - IUT/ESIROI">

  <!-- ===== NAVBAR ===== -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-transparent transition-all duration-300">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-3 group">
        <span class="inline-flex items-center bg-white rounded-xl px-4 py-2"><img src="/assets/logo-clusir-roi.png" alt="CLUSIR Reunion Ocean Indien" class="h-14 w-auto transition-transform group-hover:scale-105" /></span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#about" class="text-sm font-medium text-white/70 hover:text-clusir-red-bright transition-colors tracking-wider uppercase">A propos</a>
        <a href="#programme" class="text-sm font-medium text-white/70 hover:text-clusir-red-bright transition-colors tracking-wider uppercase">Programme</a>
        <a href="#speakers" class="text-sm font-medium text-white/70 hover:text-clusir-red-bright transition-colors tracking-wider uppercase">Speakers</a>
        <a href="#sponsors" class="text-sm font-medium text-white/70 hover:text-clusir-red-bright transition-colors tracking-wider uppercase">Sponsors</a>
        <a href="#inscription" class="btn-outline text-xs py-2 px-5">S'inscrire</a>
      </div>

      <!-- Mobile burger -->
      <button id="menu-toggle" class="md:hidden text-white" aria-label="Menu">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-navy-dark/95 backdrop-blur-lg border-t border-white/10">
      <div class="px-6 py-4 flex flex-col gap-4">
        <a href="#about" class="text-sm font-medium text-white/70 hover:text-clusir-red-bright transition-colors uppercase">A propos</a>
        <a href="#programme" class="text-sm font-medium text-white/70 hover:text-clusir-red-bright transition-colors uppercase">Programme</a>
        <a href="#speakers" class="text-sm font-medium text-white/70 hover:text-clusir-red-bright transition-colors uppercase">Speakers</a>
        <a href="#sponsors" class="text-sm font-medium text-white/70 hover:text-clusir-red-bright transition-colors uppercase">Sponsors</a>
        <a href="#inscription" class="text-sm font-medium text-white/70 hover:text-clusir-red-bright transition-colors uppercase">S'inscrire</a>
      </div>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background image with overlay -->
    <div class="absolute inset-0">
      <img src="/assets/hero-bg.jpg" alt="" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/80 via-navy-dark/70 to-navy-dark"></div>
    </div>

    <!-- Grid overlay -->
    <div class="absolute inset-0 cyber-grid"></div>

    <!-- Scan line effect -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute left-0 right-0 h-px bg-clusir-red/20 animate-scan"></div>
    </div>

    <!-- Glow orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-navy rounded-full animate-pulse-glow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-clusir-red/20 rounded-full animate-pulse-glow" style="animation-delay: 2s;"></div>

    <!-- Floating island silhouette -->
    <div class="absolute right-0 bottom-0 w-[500px] h-[500px] opacity-[0.06] animate-float pointer-events-none">
      <img src="/assets/reunion-silhouette.png" alt="" class="w-full h-full object-contain" />
    </div>

    <!-- Hero content -->
    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
      <!-- Event badge -->
      <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-5 py-2 mb-8" style="animation: slide-up 0.8s ease-out both;">
        <span class="w-2 h-2 bg-clusir-red rounded-full animate-pulse"></span>
        <span class="text-sm font-mono text-white/60 tracking-widest uppercase">Edition speciale &mdash; Cybermois 2026</span>
      </div>

      <!-- Main title -->
      <h1 class="font-display font-extrabold leading-relaxed mb-6" style="animation: slide-up 0.8s ease-out 0.15s both;">
        <span class="glitch-wrapper block">
          <span class="glitch text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight text-white" data-text="CYBER">CYBER</span>
        </span>
        <span class="block text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight">
          <span class="text-clusir-red-bright">TOUR</span>
          <span class="text-white/20 ml-2 md:ml-4">&#47;&#47;</span>
        </span>
        <span class="block text-3xl sm:text-4xl md:text-5xl tracking-[0.2em] mt-4 reunion-outline">REUNION</span>
      </h1>

      <!-- Investigation tagline -->
      <p class="font-serif text-xl sm:text-2xl text-white/50 italic mb-8 max-w-2xl mx-auto" style="animation: slide-up 0.8s ease-out 0.22s both;">
        L'enquete commence ici.
      </p>

      <!-- Date & location -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 mb-10" style="animation: slide-up 0.8s ease-out 0.3s both;">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-clusir-red-bright" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          <span class="font-display font-semibold text-lg tracking-wide">22 OCTOBRE 2026</span>
        </div>
        <span class="hidden sm:block w-1 h-1 bg-clusir-red rounded-full"></span>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-clusir-red-bright" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="font-display font-semibold text-lg tracking-wide">IUT / ESIROI &mdash; SUD</span>
        </div>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4" style="animation: slide-up 0.8s ease-out 0.45s both;">
        <a href="#inscription" class="btn-primary rounded-lg font-display">Obtenir mon acces</a>
        <a href="#programme" class="btn-outline rounded-lg font-display text-sm">Consulter le dossier</a>
      </div>

      <!-- Countdown -->
      <div class="mt-16 flex items-center justify-center gap-6 sm:gap-10" style="animation: slide-up 0.8s ease-out 0.6s both;">
        <div class="text-center">
          <span id="cd-days" class="block font-mono text-3xl sm:text-4xl font-bold text-clusir-red-bright tabular-nums">---</span>
          <span class="text-xs text-white/40 uppercase tracking-widest">Jours</span>
        </div>
        <span class="text-white/20 text-2xl font-light">:</span>
        <div class="text-center">
          <span id="cd-hours" class="block font-mono text-3xl sm:text-4xl font-bold text-white tabular-nums">--</span>
          <span class="text-xs text-white/40 uppercase tracking-widest">Heures</span>
        </div>
        <span class="text-white/20 text-2xl font-light">:</span>
        <div class="text-center">
          <span id="cd-mins" class="block font-mono text-3xl sm:text-4xl font-bold text-white tabular-nums">--</span>
          <span class="text-xs text-white/40 uppercase tracking-widest">Min</span>
        </div>
        <span class="text-white/20 text-2xl font-light">:</span>
        <div class="text-center">
          <span id="cd-secs" class="block font-mono text-3xl sm:text-4xl font-bold text-white/50 tabular-nums">--</span>
          <span class="text-xs text-white/40 uppercase tracking-widest">Sec</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30">
      <span class="text-xs tracking-widest uppercase">Enqueter</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent"></div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="about" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <!-- Section header -->
      <div class="reveal mb-20">
        <span class="font-mono text-clusir-red-bright/60 text-sm tracking-widest uppercase">Dossier 01 // Contexte</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          Ce que la presse<br/><span class="text-clusir-red-bright">ne vous dit pas</span>
        </h2>

      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Text block -->
        <div class="space-y-8">
          <p class="reveal delay-1 text-lg text-white/70 leading-relaxed">
            Chaque annee, les cyberattaques se multiplient sur les territoires ultramarins.
            Pourtant, <strong class="text-white font-semibold">personne n'en parle</strong>. Le
            <strong class="text-white font-semibold">Cyber Tour Reunion</strong> brise le silence.
            Organise dans le cadre du <strong class="text-clusir-red-bright font-semibold">Cybermois</strong>,
            il rassemble ceux qui savent, ceux qui protegent et ceux qui veulent comprendre.
          </p>
          <p class="reveal delay-2 text-lg text-white/70 leading-relaxed">
            En 2025, <strong class="text-white font-semibold">220 participants</strong> ont
            repondu a l'appel. <strong class="text-white font-semibold">600 vues</strong> sur
            la rediffusion. <strong class="text-white font-semibold">2 articles de presse</strong>.
            L'enquete continue en 2026. Plus grande. Plus profonde.
          </p>

          <!-- Stats -->
          <div class="reveal delay-3 grid grid-cols-3 gap-6 pt-6">
            <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
              <span class="block font-display font-extrabold text-3xl text-clusir-red-bright">220+</span>
              <span class="text-sm text-white/50 mt-1">Participants</span>
            </div>
            <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
              <span class="block font-display font-extrabold text-3xl text-clusir-red-bright">8</span>
              <span class="text-sm text-white/50 mt-1">Conferences</span>
            </div>
            <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
              <span class="block font-display font-extrabold text-3xl text-clusir-red-bright">600+</span>
              <span class="text-sm text-white/50 mt-1">Vues YouTube</span>
            </div>
          </div>
        </div>

        <!-- Visual block -->
        <div class="reveal-right delay-2 relative">
          <div class="relative rounded-2xl overflow-hidden border border-white/10">
            <img src="/assets/cybertour-asset-web-site.png" alt="Cyber Tour Reunion" class="w-full h-auto" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-dark/60 to-transparent"></div>
          </div>
          <!-- Decorative shield -->
          <div class="absolute -top-8 -right-8 w-24 h-24 text-clusir-red-bright/20 animate-float" style="animation-delay: 1s;">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
            </svg>
          </div>
          <!-- Glow -->
          <div class="absolute -bottom-12 -left-12 w-48 h-48 bg-navy rounded-full blur-[80px] opacity-60"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMME ===== -->
  <section id="programme" class="relative py-32 overflow-hidden">
    <!-- Diagonal bg -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-deep to-navy-dark"></div>
    <div class="absolute inset-0 cyber-grid opacity-50"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <!-- Section header -->
      <div class="reveal mb-20 text-center">
        <span class="font-mono text-clusir-red-bright/60 text-sm tracking-widest uppercase">Dossier 02 // Investigation</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          4 enquetes au coeur <span class="text-clusir-red-bright">du cyber</span>
        </h2>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-lg">
          Les sujets que personne n'ose aborder. Nous, si.
        </p>
      </div>

      <!-- Editorial stack -->
      <div class="space-y-6">
        <!-- Topic 1 -->
        <div class="reveal delay-1 topic-card bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 hover:bg-white/[0.06] transition-colors relative overflow-hidden">
          <div class="flex flex-col md:flex-row gap-6 md:gap-10">
            <div class="shrink-0 md:w-48 flex flex-col items-start">
              <span class="font-mono text-xs text-clusir-red-bright/60 tracking-widest uppercase">Enquete</span>
              <div class="w-10 h-0.5 bg-clusir-red mt-3 mb-4"></div>
              <div class="flex flex-wrap gap-2">
                <span class="text-xs font-mono bg-clusir-red/[0.08] text-clusir-red-bright/70 px-2.5 py-1 rounded-full">Investigation</span>
                <span class="text-xs font-mono bg-clusir-red/[0.08] text-clusir-red-bright/70 px-2.5 py-1 rounded-full">SecNumCloud</span>
              </div>
            </div>
            <div class="hidden md:block w-px bg-white/[0.06] self-stretch"></div>
            <div class="flex-1">
              <h3 class="font-display font-bold text-xl md:text-2xl mb-3">Le grand mensonge du Cloud</h3>
              <p class="text-white/50 leading-relaxed">
                On vous promet un Cloud "souverain". Mais ou sont reellement stockees vos donnees ? Enquete sur les coulisses de la souverainete numerique, du cadre europeen aux realites ultramarines.
              </p>
            </div>
          </div>
        </div>

        <!-- Topic 2 -->
        <div class="reveal delay-2 topic-card bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 hover:bg-white/[0.06] transition-colors relative overflow-hidden">
          <div class="flex flex-col md:flex-row gap-6 md:gap-10">
            <div class="shrink-0 md:w-48 flex flex-col items-start">
              <span class="font-mono text-xs text-cyan-400/70 tracking-widest uppercase">Revelation</span>
              <div class="w-10 h-0.5 bg-cyan-400 mt-3 mb-4"></div>
              <div class="flex flex-wrap gap-2">
                <span class="text-xs font-mono bg-cyan-400/[0.08] text-cyan-400/70 px-2.5 py-1 rounded-full">Shadow AI</span>
                <span class="text-xs font-mono bg-cyan-400/[0.08] text-cyan-400/70 px-2.5 py-1 rounded-full">Prompt Injection</span>
              </div>
            </div>
            <div class="hidden md:block w-px bg-white/[0.06] self-stretch"></div>
            <div class="flex-1">
              <h3 class="font-display font-bold text-xl md:text-2xl mb-3">L'IA : allie ou taupe ?</h3>
              <p class="text-white/50 leading-relaxed">
                ChatGPT dans vos outils internes. Copilot dans votre code. Et si l'IA que vous utilisez chaque jour etait votre plus grande surface d'attaque ? Analyse des risques et parades.
              </p>
            </div>
          </div>
        </div>

        <!-- Topic 3 -->
        <div class="reveal delay-3 topic-card bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 hover:bg-white/[0.06] transition-colors relative overflow-hidden">
          <div class="flex flex-col md:flex-row gap-6 md:gap-10">
            <div class="shrink-0 md:w-48 flex flex-col items-start">
              <span class="font-mono text-xs text-emerald-400/70 tracking-widest uppercase">Immersion</span>
              <div class="w-10 h-0.5 bg-emerald-400 mt-3 mb-4"></div>
              <div class="flex flex-wrap gap-2">
                <span class="text-xs font-mono bg-emerald-400/[0.08] text-emerald-400/70 px-2.5 py-1 rounded-full">Zero Trust</span>
                <span class="text-xs font-mono bg-emerald-400/[0.08] text-emerald-400/70 px-2.5 py-1 rounded-full">Blue Team</span>
              </div>
            </div>
            <div class="hidden md:block w-px bg-white/[0.06] self-stretch"></div>
            <div class="flex-1">
              <h3 class="font-display font-bold text-xl md:text-2xl mb-3">24h dans un SOC sous attaque</h3>
              <p class="text-white/50 leading-relaxed">
                L'alerte tombe a 3h du matin. Le SIEM s'affole. L'equipe a 15 minutes pour reagir. Plongee dans les outils, les reflexes et les architectures qui font la difference.
              </p>
            </div>
          </div>
        </div>

        <!-- Topic 4 -->
        <div class="reveal delay-4 topic-card bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 hover:bg-white/[0.06] transition-colors relative overflow-hidden">
          <div class="flex flex-col md:flex-row gap-6 md:gap-10">
            <div class="shrink-0 md:w-48 flex flex-col items-start">
              <span class="font-mono text-xs text-clusir-red-bright/60 tracking-widest uppercase">Temoignage</span>
              <div class="w-10 h-0.5 bg-clusir-red mt-3 mb-4"></div>
              <div class="flex flex-wrap gap-2">
                <span class="text-xs font-mono bg-clusir-red/[0.08] text-clusir-red-bright/70 px-2.5 py-1 rounded-full">Victimes</span>
                <span class="text-xs font-mono bg-clusir-red/[0.08] text-clusir-red-bright/70 px-2.5 py-1 rounded-full">Gestion de crise</span>
              </div>
            </div>
            <div class="hidden md:block w-px bg-white/[0.06] self-stretch"></div>
            <div class="flex-1">
              <h3 class="font-display font-bold text-xl md:text-2xl mb-3">"On pensait etre proteges"</h3>
              <p class="text-white/50 leading-relaxed">
                Ils dirigeaient une collectivite, un hopital, une PME. Un jour, tout s'est arrete. Recits de crises cyber vecues, a visage decouvert. Table ronde exceptionnelle.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SPEAKERS ===== -->
  <section id="speakers" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="reveal mb-20 text-center">
        <span class="font-mono text-clusir-red-bright/60 text-sm tracking-widest uppercase">Dossier 03 // Sources</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          Nos <span class="text-clusir-red-bright">informateurs</span>
        </h2>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-lg">
          Ils connaissent les coulisses. Ils acceptent de temoigner.
        </p>
      </div>

      <!-- Encrypted overlay container -->
      <div class="relative">
        <!-- Speaker cards (blurred) -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 blur-[6px] select-none pointer-events-none" aria-hidden="true">
          <!-- Speaker 1 -->
          <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 text-center">
            <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-navy to-slate-mid border-2 border-white/10 flex items-center justify-center">
              <span class="font-display font-bold text-3xl text-clusir-red-bright/60">??</span>
            </div>
            <h3 class="font-display font-bold text-xl">██████ ██████</h3>
            <p class="font-mono text-xs text-clusir-red-bright/50 mt-2 tracking-wider uppercase">██████████</p>
            <p class="text-white/40 text-sm mt-4 leading-relaxed">
              ████████ ██ ████████ ██ ███████ ██ █████████ ██ █████████.
            </p>
          </div>

          <!-- Speaker 2 -->
          <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 text-center">
            <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-navy to-slate-mid border-2 border-white/10 flex items-center justify-center">
              <span class="font-display font-bold text-3xl text-clusir-red-bright/60">??</span>
            </div>
            <h3 class="font-display font-bold text-xl">██████ ██████</h3>
            <p class="font-mono text-xs text-clusir-red-bright/50 mt-2 tracking-wider uppercase">██████████</p>
            <p class="text-white/40 text-sm mt-4 leading-relaxed">
              ████████ ██ ████████ ██ ███████ ██ █████████ ██ █████████.
            </p>
          </div>

          <!-- Speaker 3 -->
          <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 text-center sm:col-span-2 lg:col-span-1">
            <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-navy to-slate-mid border-2 border-white/10 flex items-center justify-center">
              <span class="font-display font-bold text-3xl text-clusir-red-bright/60">??</span>
            </div>
            <h3 class="font-display font-bold text-xl">██████ ██████</h3>
            <p class="font-mono text-xs text-clusir-red-bright/50 mt-2 tracking-wider uppercase">██████████</p>
            <p class="text-white/40 text-sm mt-4 leading-relaxed">
              ████████ ██ ████████ ██ ███████ ██ █████████ ██ █████████.
            </p>
          </div>
        </div>

        <!-- Terminal overlay -->
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="terminal-window bg-black/80 backdrop-blur-md border border-clusir-red/20 rounded-xl px-8 py-6 max-w-md w-full font-mono text-sm">
            <div class="flex items-center gap-2 mb-4 pb-3 border-b border-white/10">
              <span class="w-3 h-3 rounded-full bg-red/80"></span>
              <span class="w-3 h-3 rounded-full bg-clusir-red/60"></span>
              <span class="w-3 h-3 rounded-full bg-emerald-400/60"></span>
              <span class="ml-3 text-white/30 text-xs">speakers.decrypt</span>
            </div>
            <div class="space-y-2">
              <p class="text-emerald-400/80"><span class="text-clusir-red-bright/60">$</span> cat /sources/2026.conf</p>
              <p class="text-red/80">ERROR: Access denied. Sources protegees.</p>
              <p class="text-white/50"><span class="text-clusir-red-bright/60">$</span> decrypt --force informateurs.list</p>
              <p class="text-clusir-red-bright terminal-typing">Declassification en cours<span class="terminal-dots">...</span></p>
