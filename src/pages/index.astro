---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import MapReunion from '../components/MapReunion.astro';
import StageCard from '../components/StageCard.astro';
import PartnerPyramid from '../components/PartnerPyramid.astro';
import { stages } from '../data/stages';
---

<Layout title="Cyber Tour Reunion 2026 | 19-23 Octobre - 4 Etapes">

  <!-- ===== NAVBAR ===== -->
  <Navbar />

  <!-- ===== HERO ===== -->
  <section id="main-content" class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background image with overlay -->
    <div class="absolute inset-0">
      <img src="/assets/hero-bg.jpg" alt="" width="1920" height="1080" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/80 via-navy-dark/70 to-navy-dark"></div>
    </div>

    <!-- Grid overlay -->
    <div class="absolute inset-0 cyber-grid"></div>

    <!-- Scan line effect -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute left-0 right-0 h-px bg-gold/20 animate-scan"></div>
    </div>

    <!-- Glow orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-navy rounded-full animate-pulse-glow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-gold/20 rounded-full animate-pulse-glow" style="animation-delay: 2s;"></div>

    <!-- Floating island silhouette -->
    <div class="absolute right-0 bottom-0 w-[500px] h-[500px] opacity-[0.06] animate-float pointer-events-none">
      <img src="/assets/reunion-silhouette.png" alt="" class="w-full h-full object-contain" />
    </div>

    <!-- Hero content -->
    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
      <!-- Event badge -->
      <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-5 py-2 mb-8" style="animation: slide-up 0.8s ease-out both;">
        <span class="w-2 h-2 bg-gold rounded-full animate-pulse"></span>
        <span class="text-sm font-mono text-white/60 tracking-widest uppercase">Cybermois 2026 &mdash; La Reunion</span>
      </div>

      <!-- Main title -->
      <h1 class="font-display font-extrabold leading-relaxed mb-6" style="animation: slide-up 0.8s ease-out 0.15s both;">
        <span class="glitch-wrapper block">
          <span class="glitch text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight text-white" data-text="CYBER">CYBER</span>
        </span>
        <span class="block text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight">
          <span class="text-gold">TOUR</span>
          <span class="text-white/20 ml-2 md:ml-4">&#47;&#47;</span>
        </span>
        <span class="block text-3xl sm:text-4xl md:text-5xl tracking-[0.2em] mt-4 reunion-outline">REUNION</span>
      </h1>

      <!-- Date & location -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 mb-10" style="animation: slide-up 0.8s ease-out 0.3s both;">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          <span class="font-display font-semibold text-lg tracking-wide">19 &mdash; 23 OCTOBRE 2026</span>
        </div>
        <span class="hidden sm:block w-1 h-1 bg-gold rounded-full"></span>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="font-display font-semibold text-lg tracking-wide">4 ETAPES &middot; TOUTE L'ILE</span>
        </div>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4" style="animation: slide-up 0.8s ease-out 0.45s both;">
        <a href="#etapes" class="btn-primary rounded-lg font-display">Decouvrir le parcours</a>
        <a href="#contact" class="btn-outline rounded-lg font-display text-sm">Contact</a>
      </div>

      <!-- Countdown -->
      <div class="mt-16 flex items-center justify-center gap-6 sm:gap-10" style="animation: slide-up 0.8s ease-out 0.6s both;">
        <div class="text-center">
          <span id="cd-days" class="block font-mono text-3xl sm:text-4xl font-bold text-gold tabular-nums">---</span>
          <span class="text-xs text-white/55 uppercase tracking-widest">Jours</span>
        </div>
        <span class="text-white/20 text-2xl font-light">:</span>
        <div class="text-center">
          <span id="cd-hours" class="block font-mono text-3xl sm:text-4xl font-bold text-white tabular-nums">--</span>
          <span class="text-xs text-white/55 uppercase tracking-widest">Heures</span>
        </div>
        <span class="text-white/20 text-2xl font-light">:</span>
        <div class="text-center">
          <span id="cd-mins" class="block font-mono text-3xl sm:text-4xl font-bold text-white tabular-nums">--</span>
          <span class="text-xs text-white/55 uppercase tracking-widest">Min</span>
        </div>
        <span class="text-white/20 text-2xl font-light">:</span>
        <div class="text-center">
          <span id="cd-secs" class="block font-mono text-3xl sm:text-4xl font-bold text-white/50 tabular-nums">--</span>
          <span class="text-xs text-white/55 uppercase tracking-widest">Sec</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/45">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent"></div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="about" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <!-- Section header -->
      <div class="reveal mb-20">
        <span class="font-mono text-gold/80 text-sm tracking-widest uppercase">01 // A propos</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          L'evenement cyber<br/><span class="text-gold">de reference</span> a La Reunion
        </h2>

      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Text block -->
        <div class="space-y-8">
          <p class="reveal delay-1 text-lg text-white/70 leading-relaxed">
            <strong class="text-white font-semibold">Une semaine. Quatre etapes. Toute l'ile.</strong>
            Le <strong class="text-white font-semibold">Cyber Tour Reunion</strong> est le rendez-vous annuel
            de la cybersecurite a La Reunion. Organise dans le cadre du
            <strong class="text-gold font-semibold">Cybermois</strong> par le
            <strong class="text-white font-semibold">CLUSIR Reunion Ocean Indien</strong>,
            il reunit decideurs, professionnels et etudiants autour d'un objectif commun :
            renforcer la resilience numerique du territoire.
          </p>
          <p class="reveal delay-2 text-lg text-white/70 leading-relaxed">
            En 2025 : <strong class="text-white font-semibold">220 participants</strong>,
            <strong class="text-white font-semibold">600 vues</strong> en replay,
            <strong class="text-white font-semibold">2 articles</strong> dans Le Quotidien.
            En 2026, le format evolue avec 4 etapes du Nord au Sud pour toucher tous les publics de l'ile.
          </p>

          <!-- Stats -->
          <div class="reveal delay-3 grid grid-cols-3 gap-6 pt-6">
            <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
              <span class="block font-display font-extrabold text-3xl text-gold">4</span>
              <span class="text-sm text-white/50 mt-1">Etapes</span>
            </div>
            <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
              <span class="block font-display font-extrabold text-3xl text-gold">5</span>
              <span class="text-sm text-white/50 mt-1">Jours</span>
            </div>
            <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
              <span class="block font-display font-extrabold text-3xl text-gold">600+</span>
              <span class="text-sm text-white/50 mt-1">Vues YouTube</span>
            </div>
          </div>
        </div>

        <!-- Visual block -->
        <div class="reveal-right delay-2 relative">
          <div class="relative rounded-2xl overflow-hidden border border-white/10">
            <img src="/assets/cybertour-asset-web-site.png" alt="Cyber Tour Reunion" class="w-full h-auto" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-dark/60 to-transparent"></div>
          </div>
          <!-- Decorative shield -->
          <div class="absolute -top-8 -right-8 w-24 h-24 text-gold/20 animate-float" style="animation-delay: 1s;">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
            </svg>
          </div>
          <!-- Glow -->
          <div class="absolute -bottom-12 -left-12 w-48 h-48 bg-navy rounded-full blur-[80px] opacity-60"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CARTE DU TOUR / ETAPES ===== -->
  <section id="etapes" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-deep to-navy-dark"></div>
    <div class="absolute inset-0 cyber-grid opacity-50"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="reveal mb-20 text-center">
        <span class="font-mono text-gold/80 text-sm tracking-widest uppercase">02 // Le Parcours</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          4 etapes a travers <span class="text-gold">toute l'ile</span>
        </h2>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-lg">
          Chaque jour, un lieu. Chaque lieu, un enjeu. De Saint-Denis a Saint-Pierre, la cybersecurite fait le tour de l'ile.
        </p>
      </div>
      <MapReunion />
      <!-- Stage cards bento grid -->
      <div class="grid md:grid-cols-2 gap-6 mt-16">
        {stages.map(stage => <StageCard stage={stage} />)}
      </div>
    </div>
  </section>

  <!-- ===== SPEAKERS ===== -->
  <section id="speakers" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="reveal mb-20 text-center">
        <span class="font-mono text-gold/80 text-sm tracking-widest uppercase">03 // Speakers</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          Nos <span class="text-gold">Conferenciers</span>
        </h2>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-lg">
          Des specialistes reconnus en cybersecurite partagent leur expertise et leurs retours d'experience.
        </p>
      </div>

      <!-- Encrypted overlay container -->
      <div class="relative">
        <!-- Speaker cards (blurred) -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 blur-[6px] select-none pointer-events-none" aria-hidden="true">
          <!-- Speaker 1 -->
          <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 text-center">
            <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-navy to-slate-mid border-2 border-white/10 flex items-center justify-center">
              <span class="font-display font-bold text-3xl text-gold/80">??</span>
            </div>
            <h3 class="font-display font-bold text-xl">██████ ██████</h3>
            <p class="font-mono text-xs text-gold/70 mt-2 tracking-wider uppercase">██████████</p>
            <p class="text-white/55 text-sm mt-4 leading-relaxed">
              ████████ ██ ████████ ██ ███████ ██ █████████ ██ █████████.
            </p>
          </div>

          <!-- Speaker 2 -->
          <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 text-center">
            <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-navy to-slate-mid border-2 border-white/10 flex items-center justify-center">
              <span class="font-display font-bold text-3xl text-gold/80">??</span>
            </div>
            <h3 class="font-display font-bold text-xl">██████ ██████</h3>
            <p class="font-mono text-xs text-gold/70 mt-2 tracking-wider uppercase">██████████</p>
            <p class="text-white/55 text-sm mt-4 leading-relaxed">
              ████████ ██ ████████ ██ ███████ ██ █████████ ██ █████████.
            </p>
          </div>

          <!-- Speaker 3 -->
          <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 text-center sm:col-span-2 lg:col-span-1">
            <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-navy to-slate-mid border-2 border-white/10 flex items-center justify-center">
              <span class="font-display font-bold text-3xl text-gold/80">??</span>
            </div>
            <h3 class="font-display font-bold text-xl">██████ ██████</h3>
            <p class="font-mono text-xs text-gold/70 mt-2 tracking-wider uppercase">██████████</p>
            <p class="text-white/55 text-sm mt-4 leading-relaxed">
              ████████ ██ ████████ ██ ███████ ██ █████████ ██ █████████.
            </p>
          </div>
        </div>

        <!-- Terminal overlay -->
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="terminal-window bg-black/80 backdrop-blur-md border border-gold/20 rounded-xl px-8 py-6 max-w-md w-full font-mono text-sm">
            <div class="flex items-center gap-2 mb-4 pb-3 border-b border-white/10">
              <span class="w-3 h-3 rounded-full bg-red/80"></span>
              <span class="w-3 h-3 rounded-full bg-gold/60"></span>
              <span class="w-3 h-3 rounded-full bg-emerald-400/60"></span>
              <span class="ml-3 text-white/45 text-xs">speakers.decrypt</span>
            </div>
            <div class="space-y-2">
              <p class="text-emerald-400/80"><span class="text-gold/80">$</span> cat /speakers/2026.conf</p>
              <p class="text-red/80">ERROR: Access denied. File encrypted.</p>
              <p class="text-white/50"><span class="text-gold/80">$</span> decrypt --force speakers.list</p>
              <p class="text-gold terminal-typing">Decrypting<span class="terminal-dots">...</span></p>
              <p class="text-white/45 mt-2 text-xs">// Annonce imminente. Stay tuned.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== RETOUR SUR 2025 ===== -->
  <section id="replay" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-dark via-slate-deep to-navy-dark"></div>
    <div class="absolute inset-0 cyber-grid opacity-20"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6">
      <div class="reveal text-center mb-14">
        <span class="font-mono text-gold/80 text-sm tracking-widest uppercase">04 // Replay</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          Edition <span class="text-gold">2025</span>
        </h2>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-lg">
          Revivez les conferences de l'edition precedente en integralite.
        </p>
      </div>

      <!-- Stats 2025 -->
      <div class="reveal delay-1 grid grid-cols-3 gap-6 max-w-2xl mx-auto mb-12">
        <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
          <span class="block font-display font-extrabold text-3xl text-gold">220</span>
          <span class="text-sm text-white/50 mt-1">Participants</span>
        </div>
        <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
          <span class="block font-display font-extrabold text-3xl text-gold">150</span>
          <span class="text-sm text-white/50 mt-1">En presentiel</span>
        </div>
        <div class="text-center p-4 bg-white/[0.03] border border-white/[0.06] rounded-xl">
          <span class="block font-display font-extrabold text-3xl text-gold">600+</span>
          <span class="text-sm text-white/50 mt-1">Vues replay</span>
        </div>
      </div>

      <div class="reveal delay-2">
        <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-navy/50 aspect-video">
          <iframe
            src="https://www.youtube-nocookie.com/embed/uk-gSyaxyWA?start=9748"
            title="Cyber Tour Reunion 2025 - Replay"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            class="absolute inset-0 w-full h-full"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PARTENAIRES (Pyramid) ===== -->
  <section id="partenaires" class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-dark via-slate-deep to-navy-dark"></div>
    <div class="relative z-10">
      <div class="reveal mb-12 text-center px-6">
        <span class="font-mono text-gold/80 text-sm tracking-widest uppercase">05 // Partenaires</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          L'ecosysteme <span class="text-gold">CyberTour</span>
        </h2>
      </div>
      <PartnerPyramid />
    </div>
  </section>

  <!-- ===== SPONSORS ===== -->
  <section id="sponsors" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-dark via-slate-deep to-navy-dark"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="reveal mb-20 text-center">
        <span class="font-mono text-gold/80 text-sm tracking-widest uppercase">06 // Devenir Sponsor</span>
        <h2 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl mt-4 leading-snug">
          Devenez <span class="text-gold">partenaire</span>
        </h2>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-lg">
          Trois niveaux de sponsoring pour accompagner la cybersecurite a La Reunion.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">

        <!-- Bronze -->
        <div class="reveal delay-1 sponsor-card bg-white/[0.03] border border-amber-900/30 rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-amber-700 to-amber-900"></div>
          <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-amber-900/20 mb-4">
              <svg class="w-8 h-8 text-amber-600" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
              </svg>
            </div>
            <h3 class="font-display font-bold text-2xl">Bronze</h3>
            <p class="font-mono text-clusir-red text-xl font-bold mt-2">1 000 &euro;</p>
            <p class="text-white/55 text-sm mt-1">A partir de</p>
          </div>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-white/60 text-sm">
              <svg class="w-5 h-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              Logo sur le site web de l'evenement
            </li>
            <li class="flex items-start gap-3 text-white/60 text-sm">
              <svg class="w-5 h-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              Logo sur les supports de communication
            </li>
            <li class="flex items-start gap-3 text-white/60 text-sm">
              <svg class="w-5 h-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              Mention sur les reseaux sociaux
            </li>
          </ul>
          <div class="mt-8">
            <a href="#contact" class="block w-full text-center py-3 border border-amber-700/50 rounded-lg text-amber-500 font-display font-semibold text-sm uppercase tracking-wider hover:bg-amber-900/20 transition-colors">Devenir sponsor</a>
          </div>
        </div>

        <!-- Silver -->
        <div class="reveal delay-2 sponsor-card bg-white/[0.03] border border-gray-400/30 rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gray-300 to-gray-500"></div>
          <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-400/10 mb-4">
              <svg class="w-8 h-8 text-gray-300" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
              </svg>
            </div>
            <h3 class="font-display font-bold text-2xl">Silver</h3>
            <p class="font-mono text-clusir-red text-xl font-bold mt-2">3 000 &euro;</p>
            <p class="text-white/55 text-sm mt-1">A partir de</p>
          </div>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-white/60 text-sm">
              <svg class="w-5 h-5 text-gray-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              Tout Bronze +
            </li>
            <li class="flex items-start gap-3 text-white/60 text-sm">
              <svg class="w-5 h-5 text-gray-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              Integration de goodies participants
            </li>
            <li class="flex items-start gap-3 text-white/60 text-sm">
              <svg class="w-5 h-5 text-gray-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              2 kakemonos exterieurs
            </li>
          </ul>
