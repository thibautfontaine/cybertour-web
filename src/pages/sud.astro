---
import StageLayout from '../layouts/StageLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Timeline from '../components/Timeline.astro';
import type { TimelineItem } from '../components/Timeline.astro';
import { stages } from '../data/stages';
const stage = stages.find(s => s.id === 'sud')!;

const programmeJ1: TimelineItem[] = [
  { time: '08:00 - 08:45', title: 'Accueil des participants et petit-dejeuner' },
  { time: '09:00 - 09:30', title: 'Discours de bienvenue' },
  { isSection: true, title: 'Souverainete numerique' },
  { time: '09:30 - 10:00', title: 'Enjeux locaux et nationaux de la souverainete numerique', org: 'A CONFIRMER' },
  { time: '10:00 - 10:30', title: 'Cloud de confiance et cadre reglementaire europeen', org: 'A CONFIRMER' },
  { time: '10:30 - 11:00', title: 'Table ronde, questions/reponses avec la salle' },
  { isSection: true, title: 'Securite des systemes IA' },
  { time: '11:00 - 11:30', title: 'OWASP Top 10 GenAI : les risques de l\'IA generative', org: 'A CONFIRMER' },
  { time: '11:30 - 12:00', title: 'Protection des modeles et exfiltration de donnees', org: 'A CONFIRMER' },
  { time: '12:00 - 13:45', title: 'Cocktail dejeunatoire, reseautage et rencontres professionnels - etudiants', isPause: true },
  { isSection: true, title: 'SOC, defense proactive & Zero Trust' },
  { time: '14:00 - 14:30', title: 'Architectures Zero Trust : retour d\'experience', org: 'A CONFIRMER' },
  { time: '14:30 - 15:00', title: 'SOC et defense proactive : detecter avant l\'impact', org: 'A CONFIRMER' },
  { time: '15:00 - 15:30', title: 'Chiffrement et securisation du code source', org: 'A CONFIRMER' },
  { isSection: true, title: 'RETEX Cyber' },
  { time: '15:30 - 16:00', title: 'Retour d\'experience : gestion d\'une crise cyber', org: 'A CONFIRMER' },
  { time: '16:00 - 17:00', title: 'Table ronde et cloture de la journee' },
];

const programmeJ2: TimelineItem[] = [
  { time: '08:30 - 09:00', title: 'Accueil des participants' },
  { time: '09:00 - 09:15', title: 'Briefing de la journee ateliers' },
  { isSection: true, title: 'Ateliers du matin (sessions paralleles)' },
  { time: '09:15 - 12:00', title: 'CTF Tahir — Attack/Defense : deux equipes s\'affrontent, l\'une attaque, l\'autre defend (toute la journee)' },
  { time: '09:15 - 12:00', title: 'Gestion de crise — Simulation d\'incident cyber (4-6 groupes, session matin)', org: 'CLUSIR ROI' },
  { time: '12:00 - 13:30', title: 'Dejeuner et rencontres professionnelles', isPause: true },
  { isSection: true, title: 'Ateliers de l\'apres-midi (sessions paralleles)' },
  { time: '13:30 - 16:30', title: 'CTF Tahir — Suite du match attack/defense' },
  { time: '13:30 - 16:30', title: 'Escape Game Cyber Reunion — Escape game immersif cybersecurite', org: 'CYBER REUNION' },
  { time: '13:30 - 16:30', title: 'Atelier technique approfondi (ex : OSINT)', org: 'A CONFIRMER' },
  { time: '13:30 - 16:30', title: 'Gestion de crise — Session apres-midi (4-6 groupes)', org: 'CLUSIR ROI' },
  { isSection: true, title: 'Scene ouverte & Cloture' },
  { time: '16:30 - 17:30', title: 'Rumps — Scene ouverte : presentations libres de 5 a 10 minutes' },
  { time: '17:30 - 18:00', title: 'Remise des prix CTF et cloture officielle du CyberTour 2026' },
];

const ateliers = [
  {
    icon: '\u{1F3F4}',
    title: 'CTF Tahir',
    desc: 'CTF attack/defense sur la journee entiere. Deux equipes s\'affrontent : l\'une attaque, l\'autre defend ses services. Format dynamique, pression reelle.',
  },
  {
    icon: '\u{1F510}',
    title: 'Escape Game Cyber Reunion',
    desc: 'Escape game immersif sur le theme de la cybersecurite, concu par Cyber Reunion.',
  },
  {
    icon: '\u{1F6A8}',
    title: 'Gestion de crise',
    desc: 'Simulation de gestion d\'incident cyber en conditions reelles. 4 a 6 groupes, sessions matin et apres-midi.',
  },
  {
    icon: '\u{1F50D}',
    title: 'Atelier technique (OSINT)',
    desc: 'Atelier technique approfondi : techniques d\'investigation numerique en sources ouvertes.',
  },
  {
    icon: '\u{1F3A4}',
    title: 'Rumps — Scene ouverte',
    desc: 'Presentations libres de 5 a 10 minutes. Partagez un projet, un outil, un retour d\'experience.',
  },
  {
    icon: '\u{1F4BC}',
    title: 'Rencontres professionnelles',
    desc: 'Rencontres sponsors en one-to-one et atelier de recherche de stage avec les entreprises presentes.',
  },
];
---

<StageLayout stage={stage}>
  <Navbar slot="navbar" currentPage="sud" />

  <!-- Floating day navigator — left side -->
  <nav id="day-nav" aria-label="Navigation par jour" class="fixed left-4 top-1/2 translate-y-16 z-40 hidden lg:flex flex-col gap-4 pointer-events-none opacity-0 transition-opacity duration-300">
    <a href="#day-1" class="day-nav-btn group flex items-center gap-3 pointer-events-auto">
      <span class="day-nav-dot w-2.5 h-2.5 rounded-full border-2 transition-all duration-200 shrink-0"></span>
      <span class="day-nav-label font-mono text-xs tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap bg-[#0a1220]/90 backdrop-blur-md px-3 py-1.5 rounded-full border border-white/[0.08]">
        Jour 1 — Jeudi 22
      </span>
    </a>
    <a href="#day-2" class="day-nav-btn group flex items-center gap-3 pointer-events-auto">
      <span class="day-nav-dot w-2.5 h-2.5 rounded-full border-2 transition-all duration-200 shrink-0"></span>
      <span class="day-nav-label font-mono text-xs tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap bg-[#0a1220]/90 backdrop-blur-md px-3 py-1.5 rounded-full border border-white/[0.08]">
        Jour 2 — Vendredi 23
      </span>
    </a>
  </nav>

  <!-- Two-day programme -->
  <section id="programme" class="py-20">
    <div class="max-w-5xl mx-auto px-6">

      <!-- Jour 1: Conferences techniques -->
      <div class="day-section" id="day-1">
        <div class="reveal">
          <span class="font-mono text-red-400/60 text-sm tracking-widest uppercase">Jour 1 — Jeudi 22 octobre</span>
          <h2 class="font-display font-bold text-3xl sm:text-4xl mt-4">Conferences techniques</h2>
          <p class="text-white/50 mt-4 text-lg max-w-3xl">
            Une journee de conferences animees par des experts en cybersecurite. Retours d'experience,
            presentations techniques et echanges avec la communaute.
          </p>
        </div>

        <!-- Audience note -->
        <div class="reveal delay-2 mt-8">
          <div class="bg-red-400/[0.06] border border-red-400/[0.15] rounded-xl p-5 flex items-start gap-4">
            <div class="shrink-0 w-10 h-10 rounded-lg bg-red-400/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h4 class="font-display font-semibold text-sm mb-1 text-red-400">Public</h4>
              <p class="text-white/50 text-sm font-body">Etudiants et professionnels de l'IT</p>
            </div>
          </div>
        </div>

        <!-- Programme timeline J1 -->
        <div class="reveal delay-3 mt-10">
          <h3 class="font-display font-semibold text-xl mb-6">Programme</h3>
          <Timeline accentHex={stage.accentHex} items={programmeJ1} />
          <p class="text-white/45 text-xs font-mono mt-6">Programme provisoire — sous reserve de modifications.</p>
        </div>
      </div>

      <!-- Day separator -->
      <div class="reveal my-24 flex items-center gap-6">
        <div class="flex-1 h-px bg-white/[0.06]"></div>
        <div class="flex items-center gap-3">
          <div class="w-1.5 h-1.5 rounded-full bg-red-400/40"></div>
          <span class="font-mono text-xs text-white/25 tracking-widest uppercase">Vendredi 23 octobre</span>
          <div class="w-1.5 h-1.5 rounded-full bg-red-400/40"></div>
        </div>
        <div class="flex-1 h-px bg-white/[0.06]"></div>
      </div>

      <!-- Jour 2: Ateliers pratiques -->
      <div class="day-section" id="day-2">
        <div class="reveal">
          <span class="font-mono text-red-400/60 text-sm tracking-widest uppercase">Jour 2 — Vendredi 23 octobre</span>
          <h2 class="font-display font-bold text-3xl sm:text-4xl mt-4">Ateliers pratiques</h2>
          <p class="text-white/50 mt-4 text-lg max-w-3xl">
            Une journee les mains dans le clavier. Quatre ateliers en parallele pour experimenter
            la cybersecurite de maniere concrete et ludique.
          </p>
        </div>

        <!-- Groups note -->
        <div class="reveal delay-2 mt-8">
          <div class="bg-red-400/[0.06] border border-red-400/[0.15] rounded-xl p-5 flex items-start gap-4">
            <div class="shrink-0 w-10 h-10 rounded-lg bg-red-400/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h4 class="font-display font-semibold text-sm mb-1 text-red-400">Organisation</h4>
              <p class="text-white/50 text-sm font-body">Sessions en groupes de 4 a 6, matin et apres-midi</p>
            </div>
          </div>
        </div>

        <!-- Programme timeline J2 -->
        <div class="reveal delay-3 mt-10">
          <h3 class="font-display font-semibold text-xl mb-6">Programme</h3>
          <Timeline accentHex={stage.accentHex} items={programmeJ2} />
          <p class="text-white/45 text-xs font-mono mt-6">Programme provisoire — sous reserve de modifications.</p>
        </div>

        <!-- Atelier cards -->
        <div class="reveal delay-3 mt-10">
          <h3 class="font-display font-semibold text-xl mb-6">Les ateliers en detail</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            {ateliers.map(atelier => (
              <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-6 hover:border-red-400/20 transition-colors">
                <div class="text-3xl mb-4">{atelier.icon}</div>
                <h3 class="font-display font-semibold text-lg mb-2">{atelier.title}</h3>
                <p class="text-white/50 text-sm font-body">{atelier.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Appel a soumission Rumps -->
        <div class="reveal delay-4 mt-10">
          <div class="bg-red-400/[0.06] border border-red-400/[0.15] rounded-2xl p-8 text-center">
            <h3 class="font-display font-bold text-2xl mb-3">Appel a soumission — Scene ouverte (Rumps)</h3>
            <p class="text-white/50 text-sm font-body max-w-xl mx-auto mb-6">
              Vous avez un projet, un outil, un retour d'experience a partager ?
              Proposez une presentation de 5 a 10 minutes lors de la scene ouverte du CyberTour.
            </p>
            <a href="mailto:team@cybertour.re?subject=Soumission%20Rumps%20CyberTour%202026" class="btn-primary inline-flex items-center gap-3 rounded-xl">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Soumettre une presentation
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Co-organisateurs -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="reveal">
        <h3 class="font-display font-semibold text-xl mb-8">Co-organisateurs</h3>
        <div class="flex flex-wrap items-center justify-center gap-8">
          <div class="partner-bubble px-6 py-3">
            <img src="/assets/logo-clusir.png" alt="CLUSIR Reunion Ocean Indien" class="h-16 sm:h-20 w-auto object-contain" loading="lazy" />
          </div>
          <div class="partner-bubble px-6 py-3">
            <img src="/assets/logo-univ-reunion.png" alt="Universite de La Reunion" class="h-16 sm:h-20 w-auto object-contain" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</StageLayout>

<style>
  .day-nav-dot {
    border-color: rgba(255, 255, 255, 0.2);
    background: transparent;
  }
  .day-nav-btn:hover .day-nav-dot {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.15);
  }
  .day-nav-btn.active .day-nav-dot {
    border-color: #DF3C37;
    background: #DF3C37;
    box-shadow: 0 0 8px rgba(223, 60, 55, 0.5);
  }
  .day-nav-btn.active .day-nav-label {
    opacity: 1;
    color: #DF3C37;
    border-color: rgba(223, 60, 55, 0.3);
  }
</style>

<script>
  const nav = document.getElementById('day-nav');
  const programme = document.getElementById('programme');
  const navBtns = document.querySelectorAll<HTMLAnchorElement>('.day-nav-btn');
  const sections = document.querySelectorAll<HTMLElement>('.day-section');

  // Show/hide the nav based on whether the programme section is visible
  const programmeObserver = new IntersectionObserver(
    ([entry]) => {
      if (!nav) return;
      if (entry.isIntersecting) {
        nav.style.opacity = '1';
        nav.style.pointerEvents = 'auto';
      } else {
        nav.style.opacity = '0';
        nav.style.pointerEvents = 'none';
      }
    },
    { threshold: 0, rootMargin: '-80px 0px -20px 0px' }
  );
  if (programme) programmeObserver.observe(programme);

  // Track active day as user scrolls
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          navBtns.forEach(btn => {
            const href = btn.getAttribute('href');
            btn.classList.toggle('active', href === `#${id}`);
          });
        }
      });
    },
    { threshold: 0.15, rootMargin: '-80px 0px -40% 0px' }
  );
  sections.forEach(s => sectionObserver.observe(s));

  // Smooth scroll on nav click
  navBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(btn.getAttribute('href') ?? '');
      if (target) {
        const offset = 80; // nav height
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });
</script>
