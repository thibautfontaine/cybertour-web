---
import StageLayout from '../layouts/StageLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Timeline, { type TimelineItem } from '../components/Timeline.astro';
import { stages } from '../data/stages';
const stage = stages.find(s => s.id === 'nord')!;

const programme: TimelineItem[] = [
  { time: '08:00 - 08:30', title: 'Accueil des participants et cafe' },
  { time: '08:30 - 08:45', title: 'Ouverture officielle du CyberTour Reunion 2026', speaker: 'CLUSIR Réunion Océan Indien' },
  { isSection: true, title: 'Interventions institutionnelles' },
  { time: '08:45 - 09:00', title: 'Mot de la Presidente de Region', org: 'REGION REUNION' },
  { time: '09:00 - 09:15', title: 'Mot du President du Departement', org: 'DEPARTEMENT' },
  { time: '09:15 - 09:30', title: 'Mot du President de l\'Universite', org: 'UNIVERSITE DE LA REUNION' },
  { isSection: true, title: 'Services etatiques & cybersécurité' },
  { time: '09:30 - 10:00', title: 'Présentation du CLUSIR ROI et de l\'écosystème Cyber Reunion', org: 'CLUSIR ROI / CYBER REUNION' },
  { time: '10:00 - 10:30', title: 'La strategie nationale de cybersécurité dans les Outre-mer', org: 'ANSSI' },
  { time: '10:30 - 10:45', title: 'Pause cafe', isPause: true },
  { time: '10:45 - 11:15', title: 'Lutte contre les manipulations de l\'information et transformation numérique', org: 'VIGINUM / DINUM' },
  { time: '11:15 - 11:30', title: 'Securisation des reseaux de l\'enseignement et de la recherche', org: 'RENATER' },
  { isSection: true, title: 'Présentation du parcours CyberTour' },
  { time: '11:30 - 12:00', title: 'Présentation du parcours CyberTour 2026 — Les 4 étapes', speaker: 'CLUSIR ROI' },
  { time: '12:00 - 13:00', title: 'Cocktail dejeunatoire et networking', isPause: true },
];
---

<StageLayout stage={stage}>
  <Navbar slot="navbar" currentPage="nord" />

  <!-- Programme section -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="reveal mb-12">
        <span class="font-mono text-sm tracking-widest uppercase" style={`color: ${stage.accentHex}CC;`}>Programme</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl mt-4">Matinée institutionnelle</h2>
        <p class="text-white/50 mt-4 text-lg">Lundi 19 Octobre — 8h-13h — Campus Moufia, Saint-Denis</p>
      </div>

      <Timeline accentHex={stage.accentHex} items={programme} />

      <!-- Co-organisateurs -->
      <div class="reveal delay-1 mt-16">
        <h3 class="font-display font-semibold text-xl mb-8">Co-organisateurs</h3>
        <div class="flex flex-wrap items-center justify-center gap-8">
          <div class="partner-bubble px-6 py-3">
            <img src="/assets/logo-clusir.png" alt="CLUSIR Réunion Océan Indien" class="h-16 sm:h-20 w-auto object-contain" loading="lazy" />
          </div>
          <div class="partner-bubble px-6 py-3">
            <img src="/assets/logo-univ-reunion.png" alt="Universite de La Réunion" class="h-16 sm:h-20 w-auto object-contain" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- Institutional partners logos -->
      <div class="reveal delay-2 mt-16">
        <h3 class="font-display font-semibold text-xl mb-8">Acteurs institutionnels attendus</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          {['Region Reunion', 'Departement', 'Prefecture', 'Rectorat', 'ANSSI', 'Viginum', 'DINUM', 'SGDSN', 'Renater', 'Cyber Reunion'].map(name => (
            <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 text-center hover:border-gold/20 transition-colors">
              <span class="font-display font-semibold text-sm text-white/70">{name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</StageLayout>
