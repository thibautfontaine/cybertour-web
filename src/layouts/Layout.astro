---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Cyber Tour Réunion 2026 - 4 étapes, 19-23 Octobre 2026. Organisé par le CLUSIR Réunion Océan Indien." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f1a30" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="CLUSIR Réunion Océan Indien" />
    <meta name="keywords" content="cybersécurité, La Réunion, conférence, cybermois, CLUSIR, sécurité informatique, SOC, IA, souveraineté numérique" />

    <!-- OG Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Cyber Tour Réunion" />
    <meta property="og:image" content="https://cybertour.re/assets/og-cybertour-2026.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Cyber Tour Réunion 2026 - 19-23 Octobre - 4 étapes" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://cybertour.re/assets/og-cybertour-2026.png" />

    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Event",
      "name": "Cyber Tour Réunion 2026",
      "description": "L'événement cybersécurité de référence a La Réunion, organisé par le CLUSIR Réunion Océan Indien.",
      "startDate": "2026-10-19T08:00:00+04:00",
      "endDate": "2026-10-23T18:00:00+04:00",
      "eventStatus": "https://schema.org/EventScheduled",
      "eventAttendanceMode": "https://schema.org/MixedEventAttendanceMode",
      "location": {
        "@type": "Place",
        "name": "IUT / ESIROI",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Saint-Pierre",
          "addressRegion": "La Réunion",
          "addressCountry": "FR"
        }
      },
      "image": "https://cybertour.re/assets/og-cybertour-2026.png",
      "organizer": {
        "@type": "Organization",
        "name": "CLUSIR Réunion Océan Indien",
        "url": "https://clusir-roi.org"
      },
      "isAccessibleForFree": true,
      "inLanguage": "fr"
    })} />
  </head>
  <body class="font-body antialiased overflow-x-hidden pb-10">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:bg-gold focus:text-navy-dark focus:px-4 focus:py-2 focus:rounded-lg focus:font-bold">
      Aller au contenu principal
    </a>
    <!-- Beta access gate — Cryptolocker terminal style -->
    <div id="beta-gate" class="fixed inset-0 z-[100] bg-navy-dark flex items-center justify-center">
      <!-- Scanline effect -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden opacity-20">
        <div class="absolute left-0 right-0 h-px bg-red/40 animate-scan"></div>
      </div>
      <!-- CRT noise -->
      <div class="absolute inset-0 noise-overlay pointer-events-none"></div>

      <div class="relative max-w-lg w-full mx-6">
        <!-- Logos -->
        <div class="flex items-center justify-center gap-6 mb-8">
          <img src="/assets/logo-clusir-roi-sombre.png" alt="CLUSIR" class="h-16 sm:h-20" />
          <span class="text-white/20 font-mono text-lg">x</span>
          <img src="/assets/cybertour-2026.png" alt="Cyber Tour Réunion 2026" class="h-16 sm:h-20" />
        </div>

        <!-- Terminal window -->
        <div class="terminal-window bg-slate-deep/90 border border-white/[0.1] rounded-xl overflow-hidden">
          <!-- Title bar -->
          <div class="flex items-center gap-2 px-4 py-3 bg-white/[0.03] border-b border-white/[0.08]">
            <span class="w-3 h-3 rounded-full bg-clusir-red/80"></span>
            <span class="w-3 h-3 rounded-full bg-gold/60"></span>
            <span class="w-3 h-3 rounded-full bg-emerald-400/60"></span>
            <span class="ml-3 font-mono text-xs text-white/40">cybertour.re // acces restreint</span>
          </div>

          <div class="p-6 sm:p-10 font-mono text-base">
            <!-- Warning header -->
            <div class="text-center mb-6">
              <p class="text-gold font-bold text-xl sm:text-2xl tracking-wider uppercase">&#128274; SITE VERROUILLE</p>
              <p class="text-white/50 text-sm mt-3">Le contenu de ce site est chiffre. Cle d'acces requise.</p>
            </div>

            <!-- Countdown -->
            <div class="bg-white/[0.02] border border-white/[0.08] rounded-lg p-4 mb-6">
              <p class="text-gold/70 text-xs uppercase tracking-widest text-center mb-3">Temps avant dechiffrement public</p>
              <div class="flex items-center justify-center gap-4">
                <div class="text-center">
                  <span id="lock-days" class="block text-2xl font-bold text-gold tabular-nums">--</span>
                  <span class="text-[10px] text-white/30 uppercase">jours</span>
                </div>
                <span class="text-white/20 text-xl">:</span>
                <div class="text-center">
                  <span id="lock-hours" class="block text-2xl font-bold text-white/80 tabular-nums">--</span>
                  <span class="text-[10px] text-white/30 uppercase">heures</span>
                </div>
                <span class="text-white/20 text-xl">:</span>
                <div class="text-center">
                  <span id="lock-mins" class="block text-2xl font-bold text-white/80 tabular-nums">--</span>
                  <span class="text-[10px] text-white/30 uppercase">min</span>
                </div>
                <span class="text-white/20 text-xl">:</span>
                <div class="text-center">
                  <span id="lock-secs" class="block text-2xl font-bold text-white/40 tabular-nums">--</span>
                  <span class="text-[10px] text-white/30 uppercase">sec</span>
                </div>
              </div>
            </div>

            <!-- Terminal lines -->
            <div class="space-y-2 mb-6 text-sm">
              <p><span class="text-gold/60">root@cybertour:~$</span> <span class="text-white/60">cat /var/www/cybertour.re/status</span></p>
              <p class="text-clusir-red/80">ERROR 403: Content encrypted. Authorization required.</p>
              <p><span class="text-gold/60">root@cybertour:~$</span> <span class="text-white/60">decrypt --key ████████████</span></p>
              <p class="text-gold terminal-typing">Waiting for decryption key<span class="terminal-dots"></span></p>
            </div>

            <!-- Password input -->
            <div class="border-t border-white/10 pt-5">
              <div class="flex items-center gap-2">
                <span class="text-gold/60 text-sm shrink-0">key&gt;</span>
                <input
                  id="beta-password"
                  type="password"
                  placeholder="Entrez la cle de dechiffrement..."
                  class="flex-1 bg-transparent border-none text-gold text-sm focus:outline-none font-mono placeholder-white/20"
                  autocomplete="off"
                />
              </div>
              <p id="beta-error" class="hidden text-clusir-red text-sm mt-3">&#9888; Cle invalide. Tentative enregistree.</p>
              <button
                id="beta-submit"
                class="w-full mt-5 bg-gold/20 border border-gold/40 text-gold font-bold text-sm tracking-widest uppercase rounded-lg py-3.5 hover:bg-gold/30 transition-colors"
              >&#9654; DECHIFFRER</button>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-center gap-5 mt-6">
          <a href="https://www.linkedin.com/company/clusir-roi/" target="_blank" rel="noopener" class="flex items-center gap-2 text-white/40 hover:text-gold transition-colors text-xs font-mono">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            CLUSIR ROI
          </a>
          <span class="text-white/15">|</span>
          <a href="https://www.linkedin.com/company/cyber-reunion/" target="_blank" rel="noopener" class="flex items-center gap-2 text-white/40 hover:text-gold transition-colors text-xs font-mono">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            Cyber Reunion
          </a>
        </div>
        <p class="text-white/20 text-[10px] font-mono text-center mt-3">CLUSIR Réunion Océan Indien // Cyber Tour Réunion 2026</p>
      </div>
    </div>

    <!-- Beta banner (visible after auth) -->
    <div id="beta-banner" class="hidden fixed bottom-0 left-0 right-0 z-[60] bg-gold text-navy-dark text-center py-2 px-4 font-mono text-xs tracking-wider uppercase font-bold">
      Version beta — Site en cours de construction
    </div>

    <slot />

    <script>
      // Beta gate — cryptolocker style
      // PBKDF2-SHA256, 600k iterations — résistant au brute-force hors-ligne
      const BETA_SALT = new Uint8Array([47,218,12,99,171,3,204,88,155,61,240,17,8,133,222,74]);
      const BETA_HASH = 'fe78561427c6aaa0049c32157429dd4aa46a714bc63e8604affdcafc8a90acee';
      const gate = document.getElementById('beta-gate');
      const banner = document.getElementById('beta-banner');
      const input = document.getElementById('beta-password') as HTMLInputElement;
      const btn = document.getElementById('beta-submit');
      const err = document.getElementById('beta-error');

      async function hashPassword(pwd: string): Promise<string> {
        const keyMaterial = await crypto.subtle.importKey(
          'raw', new TextEncoder().encode(pwd), 'PBKDF2', false, ['deriveBits']
        );
        const bits = await crypto.subtle.deriveBits(
          { name: 'PBKDF2', salt: BETA_SALT, iterations: 600000, hash: 'SHA-256' },
          keyMaterial, 256
        );
        return Array.from(new Uint8Array(bits)).map(b => b.toString(16).padStart(2, '0')).join('');
      }

      function unlock() {
        if (gate) gate.style.display = 'none';
        if (banner) banner.classList.remove('hidden');
        document.body.style.overflow = '';
        window.dispatchEvent(new CustomEvent('cybertour:unlocked'));
      }

      // Fix vuln 1 — vérifier le hash dérivé, pas juste 'granted'
      // (empêche le bypass trivial localStorage.setItem(..., 'granted'))
      if (localStorage.getItem('cybertour-beta') === BETA_HASH) {
        unlock();
      } else {
        // Invalider tout token malformé ou ancien ('granted', etc.)
        localStorage.removeItem('cybertour-beta');
        document.body.style.overflow = 'hidden';
      }

      // Countdown — 10 days from now (resets each visit for demo)
      const lockTarget = Date.now() + 10 * 24 * 60 * 60 * 1000;
      function updateLockCountdown() {
        const diff = lockTarget - Date.now();
        if (diff <= 0) return;
        const d = Math.floor(diff / (1000 * 60 * 60 * 24));
        const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const s = Math.floor((diff % (1000 * 60)) / 1000);
        const dEl = document.getElementById('lock-days');
        const hEl = document.getElementById('lock-hours');
        const mEl = document.getElementById('lock-mins');
        const sEl = document.getElementById('lock-secs');
        if (dEl) dEl.textContent = String(d).padStart(2, '0');
        if (hEl) hEl.textContent = String(h).padStart(2, '0');
        if (mEl) mEl.textContent = String(m).padStart(2, '0');
        if (sEl) sEl.textContent = String(s).padStart(2, '0');
      }
      updateLockCountdown();
      setInterval(updateLockCountdown, 1000);

      // Fix vuln 3 — rate limiting : 5 tentatives, verrouillage 5 min
      const MAX_ATTEMPTS = 5;
      const LOCKOUT_MS = 5 * 60 * 1000;
      let failedAttempts = 0;

      function getLockoutRemaining(): number {
        const until = parseInt(localStorage.getItem('cybertour-lockout') || '0', 10);
        return Math.max(0, until - Date.now());
      }

      function applyLockout() {
        localStorage.setItem('cybertour-lockout', String(Date.now() + LOCKOUT_MS));
        if (btn) {
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = '⛔ ACCES BLOQUE — 5 MIN';
        }
        if (input) (input as HTMLInputElement).disabled = true;
        if (err) {
          err.textContent = '⚠ Trop de tentatives. Réessayez dans 5 minutes.';
          err.classList.remove('hidden');
        }
      }

      // Vérifier verrouillage existant au chargement
      if (getLockoutRemaining() > 0) {
        applyLockout();
      }

      async function tryAccess() {
        if (!input) return;
        if (getLockoutRemaining() > 0) return;

        // Loading state — PBKDF2 prend ~1s
        const btnEl = btn as HTMLButtonElement | null;
        if (btnEl) { btnEl.disabled = true; btnEl.textContent = '⏳ DECHIFFREMENT...'; }

        const hash = await hashPassword(input.value);

        if (hash === BETA_HASH) {
          // Fix vuln 1 — stocker le hash dérivé, pas 'granted'
          localStorage.setItem('cybertour-beta', BETA_HASH);
          localStorage.removeItem('cybertour-lockout');
          unlock();
        } else {
          failedAttempts++;
          if (btnEl) { btnEl.disabled = false; btnEl.textContent = '▶ DECHIFFRER'; }

          if (failedAttempts >= MAX_ATTEMPTS) {
            applyLockout();
          } else {
            const remaining = MAX_ATTEMPTS - failedAttempts;
            if (err) {
              err.textContent = `⚠ Cle invalide. ${remaining} tentative${remaining > 1 ? 's' : ''} restante${remaining > 1 ? 's' : ''}.`;
              err.classList.remove('hidden');
            }
            (input as HTMLInputElement).value = '';
            (input as HTMLInputElement).placeholder = 'Cle incorrecte...';
          }
        }
      }

      btn?.addEventListener('click', tryAccess);
      input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') tryAccess(); });
    </script>

    <script>
      // Scroll reveal — IntersectionObserver + scroll fallback
      const REVEAL_SEL = '.reveal:not(.visible), .reveal-left:not(.visible), .reveal-right:not(.visible)';

      function checkReveals() {
        const vh = window.innerHeight;
        document.querySelectorAll<Element>(REVEAL_SEL).forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < vh * 0.92) {
            el.classList.add('visible');
          }
        });
      }

      // IntersectionObserver as primary driver (permissive settings)
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0, rootMargin: '0px 0px 0px 0px' }
      );

      document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach((el) => {
        observer.observe(el);
      });

      // Scroll fallback — catches anything the observer misses
      window.addEventListener('scroll', checkReveals, { passive: true });
      // Re-check after beta gate unlock (scroll was locked, elements weren't in viewport)
      window.addEventListener('cybertour:unlocked', () => {
        requestAnimationFrame(checkReveals);
      });
      // Run once immediately for elements already in viewport
      checkReveals();

      // Navbar scroll effect
      const nav = document.getElementById('main-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 80) {
            nav.classList.add('bg-navy-dark/95', 'backdrop-blur-lg', 'shadow-lg');
            nav.classList.remove('bg-transparent');
          } else {
            nav.classList.remove('bg-navy-dark/95', 'backdrop-blur-lg', 'shadow-lg');
            nav.classList.add('bg-transparent');
          }
        });
      }

      // Mobile menu toggle
      const menuBtn = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
          menuBtn.setAttribute('aria-expanded', mobileMenu.classList.contains('hidden') ? 'false' : 'true');
        });
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
          });
        });
      }

      // Countdown timer
      const targetDate = new Date('2026-10-19T08:00:00+04:00').getTime();
      function updateCountdown() {
        const now = Date.now();
        const diff = targetDate - now;
        if (diff <= 0) return;

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const secs = Math.floor((diff % (1000 * 60)) / 1000);

        const dEl = document.getElementById('cd-days');
        const hEl = document.getElementById('cd-hours');
        const mEl = document.getElementById('cd-mins');
        const sEl = document.getElementById('cd-secs');
        if (dEl) dEl.textContent = String(days).padStart(3, '0');
        if (hEl) hEl.textContent = String(hours).padStart(2, '0');
        if (mEl) mEl.textContent = String(mins).padStart(2, '0');
        if (sEl) sEl.textContent = String(secs).padStart(2, '0');
      }
      updateCountdown();
      setInterval(updateCountdown, 1000);
    </script>
  </body>
</html>
