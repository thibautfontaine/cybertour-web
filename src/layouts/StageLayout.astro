---
import Layout from './Layout.astro';
import { stages } from '../data/stages';
import type { Stage } from '../data/stages';

interface Props {
  stage: Stage;
}

const { stage } = Astro.props;
const pageTitle = `${stage.name} | Cyber Tour Réunion 2026`;

const currentIndex = stages.findIndex((s) => s.id === stage.id);
const prev = currentIndex > 0 ? stages[currentIndex - 1] : null;
const next = currentIndex < stages.length - 1 ? stages[currentIndex + 1] : null;
---

<Layout title={pageTitle} description={stage.description}>
  <slot name="navbar" />

  <!-- Floating stage navigator — left side -->
  <nav aria-label="Navigation entre étapes" class="fixed left-5 top-1/2 -translate-y-1/2 z-30 hidden lg:flex flex-col items-start">
    {stages.map((s, i) => {
      const isActive = s.id === stage.id;
      const isLast   = i === stages.length - 1;
      return (
        <div class="flex flex-col items-start">
          <a
            href={s.href}
            class="snav-item group relative flex items-center gap-3"
            aria-current={isActive ? 'page' : undefined}
            style="padding:6px 0;"
          >
            <!-- Zone dot — largeur fixe pour aligner le connecteur -->
            <span class="relative flex-shrink-0 flex items-center justify-center" style="width:20px;height:20px;">
              <!-- Halo externe — actif seulement -->
              {isActive && (
                <span class="absolute inset-0 rounded-full" style={`border:1px solid ${s.accentHex}30;`}></span>
              )}
              <!-- Point central -->
              <span
                class="snav-dot block rounded-full transition-all duration-300"
                style={isActive
                  ? `width:10px;height:10px;background:${s.accentHex};box-shadow:0 0 10px ${s.accentHex}90,0 0 24px ${s.accentHex}30;`
                  : `width:6px;height:6px;background:${s.accentHex}40;`}
              ></span>
            </span>

            <!-- Label — visible pour l'actif, révélé au hover pour les inactifs -->
            <span
              class:list={[
                "font-mono text-[11px] tracking-widest uppercase whitespace-nowrap transition-all duration-200",
                isActive ? "" : "opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0"
              ]}
              style={`color:${s.accentHex};`}
            >
              {isActive ? `${s.trackNumber} · ${s.direction}` : s.direction}
            </span>
          </a>

          <!-- Connecteur — centré sur le point (margin-left = 9px = (20px - 1px) / 2) -->
          {!isLast && (
            <span
              class="block rounded-full"
              style="width:1px;height:22px;margin-left:9px;background:rgba(255,255,255,0.08);"
            ></span>
          )}
        </div>
      );
    })}
  </nav>

  <style>
    .snav-dot { flex-shrink: 0; }

    /* Dot inactif : s'illumine et grossit au hover */
    .snav-item:not([aria-current="page"]):hover .snav-dot,
    .snav-item:not([aria-current="page"]):focus-visible .snav-dot {
      filter: brightness(2);
      transform: scale(1.4);
    }

    .snav-item:focus-visible { outline: none; }

    /* Stage progress bar hover effects */
    .stage-progress-item:hover span:first-child {
      opacity: 0.85;
    }
    .stage-progress-item:focus-visible {
      outline: 2px solid rgba(255,255,255,0.4);
      outline-offset: 4px;
      border-radius: 4px;
    }
  </style>

  <!-- Mobile inter-stage nav — barre sticky en bas, masquée sur desktop -->
  <nav
    aria-label="Navigation entre étapes"
    class="fixed bottom-0 left-0 right-0 z-40 lg:hidden"
    style="background: rgba(15, 26, 48, 0.96); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-top: 1px solid rgba(255,255,255,0.08);"
  >
    <div class="flex items-center justify-between px-5 py-3 max-w-lg mx-auto">
      <!-- Étape précédente -->
      {prev ? (
        <a
          href={prev.href}
          class="flex items-center gap-2 py-1"
          style={`color:${prev.accentHex};min-width:44px;min-height:44px;`}
          aria-label={`Étape précédente : ${prev.direction}`}
        >
          <span class="text-lg leading-none" aria-hidden="true">&larr;</span>
          <span class="font-mono text-[11px] tracking-widest uppercase">{prev.direction}</span>
        </a>
      ) : <div style="min-width:44px"></div>}

      <!-- Indicateur de position -->
      <div class="flex items-center gap-2.5" role="list" aria-label="Progression">
        {stages.map((s) => {
          const isActive = s.id === stage.id;
          return (
            <a
              href={s.href}
              role="listitem"
              aria-label={`${s.direction}`}
              aria-current={isActive ? 'page' : undefined}
              class="flex items-center justify-center"
              style="width:32px;height:32px;"
            >
              <span
                class="block rounded-full transition-all duration-300"
                style={isActive
                  ? `width:10px;height:10px;background:${s.accentHex};box-shadow:0 0 8px ${s.accentHex}80;`
                  : 'width:6px;height:6px;background:rgba(255,255,255,0.2);'}
              ></span>
            </a>
          );
        })}
      </div>

      <!-- Étape suivante -->
      {next ? (
        <a
          href={next.href}
          class="flex items-center gap-2 justify-end py-1"
          style={`color:${next.accentHex};min-width:44px;min-height:44px;`}
          aria-label={`Étape suivante : ${next.direction}`}
        >
          <span class="font-mono text-[11px] tracking-widest uppercase">{next.direction}</span>
          <span class="text-lg leading-none" aria-hidden="true">&rarr;</span>
        </a>
      ) : <div style="min-width:44px"></div>}
    </div>
  </nav>

  <div style={`--stage-accent: ${stage.accentHex};`} class="pb-16 lg:pb-0">

    <!-- Hero Banner -->
    <section class="relative min-h-[40vh] flex items-end overflow-hidden">
      <!-- Background gradient with stage accent -->
      <div
        class="absolute inset-0"
        style={`background: linear-gradient(135deg, #0f1a30 0%, ${stage.accentHex}12 50%, #0f1a30 100%);`}
      ></div>

      <!-- Cyber grid overlay -->
      <div class="absolute inset-0 cyber-grid"></div>

      <!-- Noise overlay -->
      <div class="absolute inset-0 noise-overlay"></div>

      <!-- Content -->
      <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pb-12 pt-32">

        <!-- Breadcrumb -->
        <nav class="reveal mb-8" aria-label="Fil d'Ariane">
          <ol class="flex items-center gap-2 font-mono text-sm tracking-wide" style="color: var(--text-muted);">
            <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
            <li class="select-none">&gt;</li>
            <li><a href="/#etapes" class="hover:text-white transition-colors">Les Étapes</a></li>
            <li class="select-none">&gt;</li>
            <li style={`color: ${stage.accentHex};`}>{stage.direction}</li>
          </ol>
        </nav>

        <!-- Stage badge -->
        <div class="reveal delay-1 mb-4">
          <span
            class="inline-block font-mono text-xs tracking-widest uppercase px-3 py-1 rounded-full border"
            style={`color: ${stage.accentHex}; border-color: ${stage.accentHex}40; background: ${stage.accentHex}10;`}
          >
            Étape {stage.trackNumber}
          </span>
        </div>

        <!-- Title -->
        <h1 class="reveal delay-2 font-display text-4xl md:text-5xl lg:text-6xl font-bold mb-4">
          {stage.name}
        </h1>

        <!-- Theme subtitle -->
        <p class="reveal delay-3 text-lg md:text-xl font-body" style="color: var(--text-secondary);">
          {stage.theme}
        </p>

        <!-- Info bar -->
        <div class="reveal delay-4 flex flex-wrap items-center gap-4 mt-8">
          <!-- Date -->
          <div class="flex items-center gap-2 font-mono text-sm" style="color: var(--text-secondary);">
            <svg class="w-4 h-4 shrink-0" style={`color: ${stage.accentHex};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span>{stage.date}</span>
          </div>

          <span class="hidden sm:block w-px h-4 bg-white/20"></span>

          <!-- Lieu -->
          <div class="flex items-center gap-2 font-mono text-sm" style="color: var(--text-secondary);">
            <svg class="w-4 h-4 shrink-0" style={`color: ${stage.accentHex};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{stage.lieu}</span>
          </div>

          <span class="hidden sm:block w-px h-4 bg-white/20"></span>

          <!-- Capacity badge -->
          <div
            class="flex items-center gap-2 font-mono text-xs tracking-widest uppercase px-3 py-1 rounded-full"
            style={`background: ${stage.accentHex}15; color: ${stage.accentHex}; border: 1px solid ${stage.accentHex}30;`}
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{stage.capacity} places</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Page-specific content -->
    <slot />

    <!-- Navigation entre étapes — redesign avec indicateur de progression -->
    <nav aria-label="Navigation entre étapes" class="max-w-5xl mx-auto px-6 py-12">

      <!-- Indicateur de progression — visible sur tous les écrans -->
      <div class="flex items-center justify-center gap-2 mb-8">
        {stages.map((s) => {
          const isCurrent = s.id === stage.id;
          return (
            <a
              href={s.href}
              aria-label={`Étape ${s.trackNumber} — ${s.direction}`}
              aria-current={isCurrent ? 'page' : undefined}
              class="stage-progress-item group flex flex-col items-center gap-1.5"
            >
              <span
                class="block rounded-full transition-all duration-300"
                style={isCurrent
                  ? `width:32px;height:4px;background:${s.accentHex};box-shadow:0 0 8px ${s.accentHex}60;`
                  : 'width:20px;height:3px;background:rgba(255,255,255,0.15);'}
              ></span>
              <span
                class="font-mono text-[10px] tracking-widest uppercase transition-colors duration-200"
                style={isCurrent
                  ? `color:${s.accentHex};`
                  : 'color:rgba(255,255,255,0.3);'}
              >
                {s.direction}
              </span>
            </a>
          );
        })}
      </div>

      <!-- Liens prev / next — contraste amélioré -->
      <div class="flex items-center justify-between pt-4 border-t border-white/[0.06]">
        {prev ? (
          <a
            href={prev.href}
            class="group flex items-center gap-4 rounded-xl p-4 hover:bg-white/[0.04] transition-all duration-200"
          >
            <span
              class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-full border transition-colors duration-200"
              style={`border-color:${prev.accentHex}40;color:${prev.accentHex};`}
              aria-hidden="true"
            >
              &larr;
            </span>
            <div>
              <span class="block text-xs font-mono uppercase tracking-wider mb-0.5" style={`color: ${prev.accentHex};`}>Étape précédente</span>
              <span class="font-display font-semibold text-white text-lg leading-tight">{prev.direction}</span>
              <span class="block text-xs text-white/50 mt-0.5">{prev.dateShort}</span>
            </div>
          </a>
        ) : <div></div>}

        {next ? (
          <a
            href={next.href}
            class="group flex items-center gap-4 text-right rounded-xl p-4 hover:bg-white/[0.04] transition-all duration-200"
          >
            <div>
              <span class="block text-xs font-mono uppercase tracking-wider mb-0.5" style={`color: ${next.accentHex};`}>Étape suivante</span>
              <span class="font-display font-semibold text-white text-lg leading-tight">{next.direction}</span>
              <span class="block text-xs text-white/50 mt-0.5">{next.dateShort}</span>
            </div>
            <span
              class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-full border transition-colors duration-200"
              style={`border-color:${next.accentHex}40;color:${next.accentHex};`}
              aria-hidden="true"
            >
              &rarr;
            </span>
          </a>
        ) : <div></div>}
      </div>
    </nav>

    <!-- Infos Pratiques -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="reveal font-display text-2xl md:text-3xl font-bold mb-10 text-center">
          Infos Pratiques
        </h2>

        <div class="reveal delay-1 bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8">
          <div class="flex items-start gap-5">
            <!-- Location icon -->
            <div
              class="shrink-0 w-12 h-12 rounded-xl flex items-center justify-center"
              style={`background: ${stage.accentHex}15;`}
            >
              <svg class="w-6 h-6" style={`color: ${stage.accentHex};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>

            <div>
              <h3 class="font-display text-lg font-semibold mb-1">Adresse</h3>
              <p class="font-body" style="color: var(--text-secondary);">{stage.lieuFull}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Inscription placeholder -->
    <section class="py-20 px-6" style="background: var(--bg-secondary);">
      <div class="max-w-3xl mx-auto text-center">
        <div class="reveal bg-white/[0.03] border border-white/[0.06] rounded-2xl p-12">
          <div
            class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-6"
            style={`background: ${stage.accentHex}15;`}
          >
            <svg class="w-8 h-8" style={`color: ${stage.accentHex};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
            </svg>
          </div>

          <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">
            Inscription bientôt disponible
          </h2>

          <p class="font-body mb-8 max-w-lg mx-auto" style="color: var(--text-secondary);">
            Les inscriptions pour cette étape ouvriront prochainement. Contactez-nous pour etre informé des qu'elles seront disponibles.
          </p>

          <a
            href="mailto:team@cybertour.re"
            class="btn-primary inline-flex items-center gap-3 rounded-xl"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Nous contacter
          </a>

          <p class="mt-4 font-mono text-xs tracking-wide" style="color: var(--text-muted);">
            team@cybertour.re
          </p>
        </div>
      </div>
    </section>

  </div>
  <slot name="footer" />
</Layout>
